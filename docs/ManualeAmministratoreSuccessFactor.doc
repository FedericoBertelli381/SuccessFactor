    <tr><td>Performance Import Admin</td><td><span class="code">/admin/performance-import</span></td><td>Master Import HR</td></tr>
    <tr><td>Notifications Admin</td><td><span class="code">/admin/notifications</span></td><td>Configurazione notifiche</td></tr>
