    <tr><td>Competency Catalog Admin</td><td><span class="code">/admin/competency-catalog</span></td><td>Catalogo competenze</td></tr>
    <tr><td>Competency Models Admin</td><td><span class="code">/admin/competency-models</span></td><td>Modelli competenze</td></tr>
