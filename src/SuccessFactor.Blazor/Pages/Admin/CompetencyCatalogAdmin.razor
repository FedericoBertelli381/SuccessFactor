@page "/admin/competency-catalog"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using SuccessFactor.Admin
@inject IAdminCompetencyCatalogAppService AdminCompetencyCatalogAppService

<PageTitle>Competency Catalog Admin</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Competency Catalog Admin</h2>
            <div class="text-muted">Gestione catalogo competenze del tenant con active flag e delete protetto se referenziata.</div>
        </div>

        <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Aggiorna
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">@_successMessage</div>
    }

    @if (_loading && _data is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento competency catalog...</span>
        </div>
    }
    else if (_data is not null)
    {
        <div class="row g-3">
            <div class="col-12 col-xxl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <strong>@(_form.CompetencyId.HasValue ? "Modifica competency" : "Nuova competency")</strong>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ResetForm">Nuova</button>
                    </div>
                    <div class="card-body">
                        <EditForm Model="_form" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />
                            <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                            <div class="row g-3">
                                <div class="col-12 col-md-4">
                                    <label class="form-label">Code</label>
                                    <InputText class="form-control text-uppercase" @bind-Value="_form.Code" />
                                </div>
                                <div class="col-12 col-md-8">
                                    <label class="form-label">Name</label>
                                    <InputText class="form-control" @bind-Value="_form.Name" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <InputTextArea class="form-control" rows="4" @bind-Value="_form.Description" />
                                </div>
                                <div class="col-12">
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" />
                                        <label class="form-check-label">Active</label>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-4">
                                <button class="btn btn-primary" type="submit" disabled="@_saving">
                                    @if (_saving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Salva competency
                                </button>
                                <button class="btn btn-outline-secondary" type="button" @onclick="ResetForm">
                                    Annulla
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xxl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <strong>Competency catalog</strong>
                            <span class="badge text-bg-light">@GetFilteredCompetencies().Count / @_data.Competencies.Count</span>
                        </div>
                        <div class="row g-2 mt-2">
                            <div class="col-12 col-lg-7">
                                <input class="form-control"
                                       placeholder="Cerca code, name o description..."
                                       @bind="_search"
                                       @bind:event="oninput" />
                            </div>
                            <div class="col-12 col-lg-5">
                                <select class="form-select" @bind="_activeFilter">
                                    <option value="">Tutte</option>
                                    <option value="active">Active</option>
                                    <option value="inactive">Inactive</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (GetFilteredCompetencies().Count == 0)
                        {
                            <div class="text-muted">Nessuna competency trovata con i filtri correnti.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Code</th>
                                            <th>Name</th>
                                            <th>Status</th>
                                            <th>Model items</th>
                                            <th>Assessment items</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in GetFilteredCompetencies())
                                        {
                                            <tr class="@(_form.CompetencyId == item.CompetencyId ? "table-primary" : null)">
                                                <td class="fw-semibold">@item.Code</td>
                                                <td>
                                                    <div class="fw-semibold">@item.Name</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                                    {
                                                        <div class="small text-muted">@item.Description</div>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                                        @(item.IsActive ? "Active" : "Inactive")
                                                    </span>
                                                </td>
                                                <td>@item.ModelItemCount</td>
                                                <td>@item.AssessmentItemCount</td>
                                                <td class="text-end">
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(item)">Modifica</button>
                                                        <button class="btn btn-sm btn-outline-danger"
                                                                disabled="@(!item.CanDelete)"
                                                                title="@GetDeleteTitle(item)"
                                                                @onclick="() => DeleteAsync(item.CompetencyId)">
                                                            Rimuovi
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading;
    private bool _saving;
    private string? _error;
    private string? _successMessage;
    private CompetencyCatalogAdminDto? _data;
    private CompetencyCatalogFormModel _form = new();
    private string? _search;
    private string? _activeFilter;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await AdminCompetencyCatalogAppService.GetAsync();

            if (!_form.CompetencyId.HasValue)
            {
                ResetForm();
            }
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        _successMessage = null;

        try
        {
            await AdminCompetencyCatalogAppService.SaveAsync(_form.CompetencyId, new SaveCompetencyCatalogItemInput
            {
                Code = _form.Code ?? string.Empty,
                Name = _form.Name ?? string.Empty,
                Description = _form.Description,
                IsActive = _form.IsActive
            });

            _successMessage = _form.CompetencyId.HasValue
                ? "Competency aggiornata correttamente."
                : "Competency creata correttamente.";

            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync(Guid competencyId)
    {
        _error = null;
        _successMessage = null;

        try
        {
            await AdminCompetencyCatalogAppService.DeleteAsync(competencyId);
            _successMessage = "Competency rimossa correttamente.";
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
    }

    private void Edit(CompetencyCatalogAdminListItemDto item)
    {
        _form = new CompetencyCatalogFormModel
        {
            CompetencyId = item.CompetencyId,
            Code = item.Code,
            Name = item.Name,
            Description = item.Description,
            IsActive = item.IsActive
        };
    }

    private void ResetForm()
    {
        _form = new CompetencyCatalogFormModel();
    }

    private List<CompetencyCatalogAdminListItemDto> GetFilteredCompetencies()
    {
        if (_data is null)
        {
            return [];
        }

        var query = _data.Competencies.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var search = _search.Trim();
            query = query.Where(x =>
                x.Code.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                x.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.Description) && x.Description.Contains(search, StringComparison.OrdinalIgnoreCase)));
        }

        if (!string.IsNullOrWhiteSpace(_activeFilter))
        {
            query = _activeFilter == "active"
                ? query.Where(x => x.IsActive)
                : query.Where(x => !x.IsActive);
        }

        return query
            .OrderByDescending(x => x.IsActive)
            .ThenBy(x => x.Code)
            .ThenBy(x => x.Name)
            .ToList();
    }

    private static string GetDeleteTitle(CompetencyCatalogAdminListItemDto item)
        => item.CanDelete
            ? "Rimuovi competency"
            : "Non rimovibile: la competency e referenziata da model item o assessment item.";

    private static string GetFriendlyErrorMessage(Exception ex)
    {
        var message = ex.Message;

        if (message.Contains("CompetencyCodeAlreadyExists", StringComparison.OrdinalIgnoreCase))
        {
            return "Esiste gia una competency con lo stesso code.";
        }

        if (message.Contains("CompetencyIsReferenced", StringComparison.OrdinalIgnoreCase))
        {
            return "La competency non puo essere rimossa: e referenziata da model item o assessment item.";
        }

        return message;
    }

    private class CompetencyCatalogFormModel
    {
        public Guid? CompetencyId { get; set; }

        [Required]
        [StringLength(50)]
        public string? Code { get; set; }

        [Required]
        [StringLength(200)]
        public string? Name { get; set; }

        public string? Description { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
