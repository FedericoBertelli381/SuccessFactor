@page "/admin/cycle-participants"
@attribute [Authorize(Roles = SuccessFactorRoles.Admin)]
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using SuccessFactor.Admin
@inject IAdminCycleParticipantAppService AdminCycleParticipantAppService
@inject NavigationManager NavigationManager

<PageTitle>Cycle Participants Admin</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Cycle Participants Admin</h2>
            <div class="text-muted">Gestione partecipanti ciclo con ricerca, bulk add e reset fase controllato.</div>
        </div>

        <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Aggiorna
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">@_successMessage</div>
    }

    @if (_loading && _data is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento cycle participants...</span>
        </div>
    }
    else if (_data is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xxl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Selezione ciclo</strong>
                    </div>
                    <div class="card-body">
                        <label class="form-label">Ciclo</label>
                        <select class="form-select"
                                value="@(_selectedCycleId?.ToString() ?? string.Empty)"
                                @onchange="OnCycleChangedAsync">
                            @if (_data.Cycles.Count == 0)
                            {
                                <option value="">Nessun ciclo disponibile</option>
                            }
                            else
                            {
                                @foreach (var cycle in _data.Cycles)
                                {
                                    <option value="@cycle.CycleId">@cycle.Name (@cycle.CycleYear - @cycle.Status)</option>
                                }
                            }
                        </select>

                        @if (_data.SelectedCycleId.HasValue)
                        {
                            <div class="small text-muted mt-3">
                                ciclo selezionato: @_data.SelectedCycleName
                                <br />
                                status: @_data.SelectedCycleStatus
                                <br />
                                fase ciclo: @GetSelectedCyclePhaseLabel()
                                <br />
                                partecipanti: @_data.Participants.Count
                            </div>

                            @if (!_data.CanEditSelectedCycle)
                            {
                                <div class="alert alert-warning mt-3 mb-0">
                                    Il ciclo selezionato e chiuso: i participant non sono modificabili.
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xxl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <strong>@(_form.ParticipantId.HasValue ? "Modifica participant" : "Nuovo participant")</strong>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ResetForm">Nuovo</button>
                    </div>
                    <div class="card-body">
                        <EditForm Model="_form" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />
                            <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                            <div class="row g-3">
                                <div class="col-12 col-md-5">
                                    <label class="form-label">Employee</label>
                                    <InputSelect class="form-select" @bind-Value="_form.EmployeeId" disabled="@(_form.ParticipantId.HasValue || !CanEditSelectedCycle())">
                                        <option value="">Seleziona employee</option>
                                        @foreach (var employee in GetAvailableEmployees())
                                        {
                                            <option value="@employee.EmployeeId.ToString()">@employee.Matricola - @employee.FullName</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="form-label">Current phase</label>
                                    <InputSelect class="form-select" @bind-Value="_form.CurrentPhaseId" disabled="@(!CanEditSelectedCycle())">
                                        <option value="">-</option>
                                        @foreach (var phase in _data.Phases)
                                        {
                                            <option value="@phase.PhaseId.ToString()">@phase.PhaseOrder - @phase.PhaseCode</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12 col-md-3">
                                    <label class="form-label">Status</label>
                                    <InputSelect class="form-select" @bind-Value="_form.Status" disabled="@(!CanEditSelectedCycle())">
                                        <option value="Active">Active</option>
                                        <option value="Completed">Completed</option>
                                        <option value="Excluded">Excluded</option>
                                    </InputSelect>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-4">
                                <button class="btn btn-primary" type="submit" disabled="@(_saving || !_data.SelectedCycleId.HasValue || !CanEditSelectedCycle())">
                                    @if (_saving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Salva participant
                                </button>
                                <button class="btn btn-outline-secondary" type="button" @onclick="ResetForm">
                                    Annulla
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <strong>Azioni bulk</strong>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-lg-5">
                        <label class="form-label">Fase da assegnare</label>
                        <select class="form-select" @bind="_bulkPhaseId" disabled="@(!CanEditSelectedCycle())">
                            <option value="">-</option>
                            @foreach (var phase in _data.Phases)
                            {
                                <option value="@phase.PhaseId.ToString()">@phase.PhaseOrder - @phase.PhaseCode - @phase.PhaseName</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-lg-3">
                        <label class="form-label">Status nuovi participant</label>
                        <select class="form-select" @bind="_bulkStatus" disabled="@(!CanEditSelectedCycle())">
                            <option value="Active">Active</option>
                            <option value="Completed">Completed</option>
                            <option value="Excluded">Excluded</option>
                        </select>
                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-primary"
                                    type="button"
                                    disabled="@(_saving || !CanEditSelectedCycle())"
                                    @onclick="BulkAddActiveEmployeesAsync">
                                Aggiungi employee attivi mancanti
                            </button>
                            <button class="btn btn-outline-warning"
                                    type="button"
                                    disabled="@(_saving || !CanEditSelectedCycle() || string.IsNullOrWhiteSpace(_bulkPhaseId) || _data.Participants.Count == 0)"
                                    @onclick="ResetParticipantsPhaseAsync">
                                Allinea fase participant
                            </button>
                        </div>
                    </div>
                </div>
                <div class="small text-muted mt-3">
                    Bulk add inserisce solo employee attivi non ancora presenti nel ciclo. Allinea fase aggiorna tutti i participant del ciclo selezionato alla fase indicata.
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <strong>Partecipanti ciclo</strong>
                    <span class="badge text-bg-light">@GetFilteredParticipants().Count / @_data.Participants.Count</span>
                </div>
                <div class="row g-2 mt-2">
                    <div class="col-12 col-lg-6">
                        <input class="form-control"
                               placeholder="Cerca matricola, nome o email..."
                               @bind="_participantSearch"
                               @bind:event="oninput" />
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <select class="form-select" @bind="_statusFilter">
                            <option value="">Tutti gli status</option>
                            <option value="Active">Active</option>
                            <option value="Completed">Completed</option>
                            <option value="Excluded">Excluded</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <select class="form-select" @bind="_phaseFilter">
                            <option value="">Tutte le fasi</option>
                            <option value="-">Senza fase</option>
                            @foreach (var phase in _data.Phases)
                            {
                                <option value="@phase.PhaseId.ToString()">@phase.PhaseOrder - @phase.PhaseCode</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (GetFilteredParticipants().Count == 0)
                {
                    <div class="text-muted">Nessun partecipante trovato con i filtri correnti.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Matricola</th>
                                    <th>Employee</th>
                                    <th>Email</th>
                                    <th>Fase</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in GetFilteredParticipants())
                                {
                                    <tr class="@(_form.ParticipantId == item.ParticipantId ? "table-primary" : null)">
                                        <td>@item.Matricola</td>
                                        <td class="fw-semibold">@item.EmployeeName</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.EmployeeEmail) ? "-" : item.EmployeeEmail)</td>
                                        <td>
                                            <div>@(item.CurrentPhaseCode ?? "-")</div>
                                            <div class="small text-muted">@item.CurrentPhaseName</div>
                                        </td>
                                        <td>
                                            <span class="badge text-bg-light">@item.Status</span>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(item)">Modifica</button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        disabled="@(!CanEditSelectedCycle())"
                                                        @onclick="() => DeleteAsync(item.ParticipantId)">
                                                    Rimuovi
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "cycleId")]
    public Guid? CycleId { get; set; }

    private bool _loading;
    private bool _saving;
    private string? _error;
    private string? _successMessage;
    private Guid? _selectedCycleId;
    private CycleParticipantAdminDto? _data;
    private ParticipantFormModel _form = new();
    private string? _participantSearch;
    private string? _statusFilter;
    private string? _phaseFilter;
    private string? _bulkPhaseId;
    private string _bulkStatus = "Active";

    protected override async Task OnParametersSetAsync()
    {
        _selectedCycleId = CycleId;
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await AdminCycleParticipantAppService.GetAsync(_selectedCycleId);
            _selectedCycleId = _data.SelectedCycleId;
            _bulkPhaseId ??= _data.SelectedCycleCurrentPhaseId?.ToString()
                ?? _data.Phases.OrderBy(x => x.PhaseOrder).FirstOrDefault()?.PhaseId.ToString();

            if (!_form.ParticipantId.HasValue)
            {
                ResetForm();
            }
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnCycleChangedAsync(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var cycleId))
        {
            return Task.CompletedTask;
        }

        _selectedCycleId = cycleId;
        _bulkPhaseId = null;
        ResetForm();

        NavigationManager.NavigateTo(BuildUrl(cycleId));
        return Task.CompletedTask;
    }

    private async Task SaveAsync()
    {
        if (_data is null || !_data.SelectedCycleId.HasValue)
        {
            return;
        }

        _saving = true;
        _error = null;
        _successMessage = null;

        try
        {
            await AdminCycleParticipantAppService.SaveAsync(_form.ParticipantId, new SaveCycleParticipantInput
            {
                CycleId = _data.SelectedCycleId.Value,
                EmployeeId = ParseGuidOrNull(_form.EmployeeId) ?? Guid.Empty,
                CurrentPhaseId = ParseGuidOrNull(_form.CurrentPhaseId),
                Status = _form.Status ?? "Active"
            });

            _successMessage = _form.ParticipantId.HasValue
                ? "Participant aggiornato correttamente."
                : "Participant aggiunto correttamente.";

            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task BulkAddActiveEmployeesAsync()
    {
        if (_data is null || !_data.SelectedCycleId.HasValue)
        {
            return;
        }

        _saving = true;
        _error = null;
        _successMessage = null;

        try
        {
            var created = await AdminCycleParticipantAppService.BulkAddActiveEmployeesAsync(new BulkAddCycleParticipantsInput
            {
                CycleId = _data.SelectedCycleId.Value,
                CurrentPhaseId = ParseGuidOrNull(_bulkPhaseId),
                Status = _bulkStatus
            });

            _successMessage = created == 0
                ? "Nessun nuovo participant da aggiungere."
                : $"{created} participant aggiunti correttamente.";

            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ResetParticipantsPhaseAsync()
    {
        if (_data is null || !_data.SelectedCycleId.HasValue)
        {
            return;
        }

        var phaseId = ParseGuidOrNull(_bulkPhaseId);
        if (!phaseId.HasValue)
        {
            _error = "Seleziona una fase prima di allineare i participant.";
            return;
        }

        _saving = true;
        _error = null;
        _successMessage = null;

        try
        {
            var updated = await AdminCycleParticipantAppService.ResetParticipantsPhaseAsync(new ResetCycleParticipantsPhaseInput
            {
                CycleId = _data.SelectedCycleId.Value,
                CurrentPhaseId = phaseId.Value
            });

            _successMessage = $"{updated} participant allineati alla fase selezionata.";
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync(Guid participantId)
    {
        _error = null;
        _successMessage = null;

        try
        {
            await AdminCycleParticipantAppService.DeleteAsync(participantId);
            _successMessage = "Participant rimosso correttamente.";
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
    }

    private void Edit(CycleParticipantAdminListItemDto item)
    {
        _form = new ParticipantFormModel
        {
            ParticipantId = item.ParticipantId,
            EmployeeId = item.EmployeeId.ToString(),
            CurrentPhaseId = item.CurrentPhaseId?.ToString(),
            Status = item.Status
        };
    }

    private void ResetForm()
    {
        _form = new ParticipantFormModel
        {
            Status = "Active",
            CurrentPhaseId = _data?.Phases.OrderBy(x => x.PhaseOrder).FirstOrDefault()?.PhaseId.ToString()
        };
    }

    private bool CanEditSelectedCycle()
        => _data?.CanEditSelectedCycle == true;

    private string GetSelectedCyclePhaseLabel()
    {
        if (_data is null || !_data.SelectedCycleCurrentPhaseId.HasValue)
        {
            return "-";
        }

        return string.IsNullOrWhiteSpace(_data.SelectedCycleCurrentPhaseCode)
            ? _data.SelectedCycleCurrentPhaseId.Value.ToString()
            : $"{_data.SelectedCycleCurrentPhaseCode} - {_data.SelectedCycleCurrentPhaseName}";
    }

    private List<CycleParticipantAdminListItemDto> GetFilteredParticipants()
    {
        if (_data is null)
        {
            return [];
        }

        var query = _data.Participants.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_participantSearch))
        {
            var search = _participantSearch.Trim();
            query = query.Where(x =>
                x.Matricola.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                x.EmployeeName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.EmployeeEmail) && x.EmployeeEmail.Contains(search, StringComparison.OrdinalIgnoreCase)));
        }

        if (!string.IsNullOrWhiteSpace(_statusFilter))
        {
            query = query.Where(x => string.Equals(x.Status, _statusFilter, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_phaseFilter))
        {
            query = _phaseFilter == "-"
                ? query.Where(x => !x.CurrentPhaseId.HasValue)
                : query.Where(x => x.CurrentPhaseId == ParseGuidOrNull(_phaseFilter));
        }

        return query
            .OrderBy(x => x.Matricola)
            .ThenBy(x => x.EmployeeName)
            .ToList();
    }

    private List<EmployeeAdminListItemDto> GetAvailableEmployees()
    {
        if (_data is null)
        {
            return [];
        }

        var participantEmployeeIds = _data.Participants
            .Where(x => !_form.ParticipantId.HasValue || x.EmployeeId != ParseGuidOrNull(_form.EmployeeId))
            .Select(x => x.EmployeeId)
            .ToHashSet();

        return _data.Employees
            .Where(x => !participantEmployeeIds.Contains(x.EmployeeId))
            .OrderBy(x => x.Matricola)
            .ThenBy(x => x.FullName)
            .ToList();
    }

    private string BuildUrl(Guid cycleId)
    {
        var url = QueryHelpers.AddQueryString("/admin/cycle-participants", "cycleId", cycleId.ToString());
        var tenant = GetCurrentTenantFromUrl();

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        return url;
    }

    private string? GetCurrentTenantFromUrl()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("__tenant", out var tenantValues))
        {
            var tenant = tenantValues.ToString();
            return string.IsNullOrWhiteSpace(tenant) ? null : tenant;
        }

        return null;
    }

    private static Guid? ParseGuidOrNull(string? value)
        => Guid.TryParse(value, out var parsed) ? parsed : null;

    private static string GetFriendlyErrorMessage(Exception ex)
    {
        var message = ex.Message;

        if (message.Contains("ClosedCycleParticipantsCannotBeChanged", StringComparison.OrdinalIgnoreCase))
        {
            return "Il ciclo selezionato e chiuso: i participant non sono modificabili.";
        }

        if (message.Contains("CycleParticipantAlreadyExists", StringComparison.OrdinalIgnoreCase))
        {
            return "Il dipendente selezionato e gia participant del ciclo.";
        }

        if (message.Contains("EmployeeNotFoundOrInactive", StringComparison.OrdinalIgnoreCase))
        {
            return "Employee non trovato o non attivo.";
        }

        if (message.Contains("PhaseNotInTemplate", StringComparison.OrdinalIgnoreCase))
        {
            return "La fase selezionata non appartiene al template del ciclo.";
        }

        if (message.Contains("CycleParticipantStatusInvalid", StringComparison.OrdinalIgnoreCase))
        {
            return "Status participant non valido.";
        }

        return message;
    }

    private class ParticipantFormModel
    {
        public Guid? ParticipantId { get; set; }
        public string? EmployeeId { get; set; }
        public string? CurrentPhaseId { get; set; }
        public string? Status { get; set; } = "Active";
    }
}
