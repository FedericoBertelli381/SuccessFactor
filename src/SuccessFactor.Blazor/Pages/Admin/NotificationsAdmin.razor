@page "/admin/notifications"
@attribute [Authorize(Roles = SuccessFactorRoles.Admin)]
@using SuccessFactor.Admin
@inject INotificationAdminAppService NotificationAdminAppService

<PageTitle>Notification Admin</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Notification Admin</h2>
            <div class="text-muted">Verifica configurazione email, template e invio di test.</div>
        </div>

        <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Aggiorna
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-success mb-4">@_message</div>
    }

    @if (_loading && _data is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento notifiche...</span>
        </div>
    }
    else if (_data is not null)
    {
        <div class="@GetReadinessAlertClass()">
            <strong>Stato email:</strong>
            @if (_data.IsReady)
            {
                <span> configurazione pronta per invio SMTP.</span>
            }
            else
            {
                <span> configurazione incompleta o invio disabilitato.</span>
            }
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Configurazione</strong>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Enabled</dt>
                            <dd class="col-sm-8">@(_data.EmailEnabled ? "Si" : "No")</dd>
                            <dt class="col-sm-4">Provider</dt>
                            <dd class="col-sm-8">@_data.Provider</dd>
                            <dt class="col-sm-4">Host</dt>
                            <dd class="col-sm-8">@Display(_data.Host)</dd>
                            <dt class="col-sm-4">Porta</dt>
                            <dd class="col-sm-8">@_data.Port</dd>
                            <dt class="col-sm-4">SSL</dt>
                            <dd class="col-sm-8">@(_data.EnableSsl ? "Si" : "No")</dd>
                            <dt class="col-sm-4">From</dt>
                            <dd class="col-sm-8">@Display(_data.FromAddress)</dd>
                            <dt class="col-sm-4">Nome mittente</dt>
                            <dd class="col-sm-8">@Display(_data.FromName)</dd>
                            <dt class="col-sm-4">Credenziali</dt>
                            <dd class="col-sm-8">@(_data.HasUserName ? "Username configurato" : "Username assente") / @(_data.HasPassword ? "password configurata" : "password assente")</dd>
                        </dl>

                        @if (_data.MissingSettings.Count > 0)
                        {
                            <hr />
                            <div class="fw-semibold mb-2">Impostazioni mancanti</div>
                            <ul class="mb-0">
                                @foreach (var setting in _data.MissingSettings)
                                {
                                    <li><code>@setting</code></li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Mail di test</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Destinatario</label>
                            <input class="form-control" @bind="_testTo" @bind:event="oninput" placeholder="nome.cognome@azienda.it" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Template</label>
                            <select class="form-select" @bind="_testTemplateCode">
                                @foreach (var template in _data.Templates)
                                {
                                    <option value="@template.Code">@template.Name</option>
                                }
                            </select>
                        </div>
                        <button class="btn btn-primary" @onclick="SendTestAsync" disabled="@(_loading || !_data.IsReady)">
                            Invia test
                        </button>
                        @if (!_data.IsReady)
                        {
                            <div class="small text-muted mt-2">Completa la configurazione SMTP per abilitare il test.</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong>Template</strong>
                <span class="badge text-bg-light">@_data.Templates.Count</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Codice</th>
                                <th>Nome</th>
                                <th>Oggetto</th>
                                <th>Anteprima</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var template in _data.Templates)
                            {
                                <tr>
                                    <td><code>@template.Code</code></td>
                                    <td class="fw-semibold">@template.Name</td>
                                    <td>@template.Subject</td>
                                    <td><pre class="small mb-0">@template.BodyPreview</pre></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading;
    private string? _error;
    private string? _message;
    private string? _testTo;
    private string? _testTemplateCode;
    private NotificationReadinessDto? _data;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await NotificationAdminAppService.GetReadinessAsync();
            _testTemplateCode ??= _data.Templates.FirstOrDefault()?.Code;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SendTestAsync()
    {
        _loading = true;
        _error = null;
        _message = null;

        try
        {
            await NotificationAdminAppService.SendTestEmailAsync(new SendTestNotificationInput
            {
                To = _testTo ?? string.Empty,
                TemplateCode = _testTemplateCode
            });
            _message = "Mail di test inviata.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetReadinessAlertClass()
        => _data?.IsReady == true ? "alert alert-success mb-4" : "alert alert-warning mb-4";

    private static string Display(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
