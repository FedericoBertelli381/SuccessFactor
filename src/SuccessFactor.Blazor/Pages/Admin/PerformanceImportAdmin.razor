@page "/admin/performance-import"
@attribute [Authorize(Roles = SuccessFactorRoles.Admin)]
@using SuccessFactor.Admin
@inject IPerformanceSetupImportAppService PerformanceSetupImportAppService

<PageTitle>Performance Import Admin</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Master Import HR</h2>
            <div class="text-muted">Import unico per onboarding tenant, assetto organizzativo, accessi applicativi e setup performance con validazione completa e no partial save.</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">@_successMessage</div>
    }

    <div class="row g-3">
        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import OrgUnits</strong>
                    <span class="badge text-bg-light">OrgUnits</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>Name;ParentName</code>. ParentName puo essere vuoto o <code>-</code>.
                    </div>

                    <textarea class="form-control"
                              rows="8"
                              @bind="_orgUnitsContent"
                              placeholder="Name;ParentName"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import JobRoles</strong>
                    <span class="badge text-bg-light">JobRoles</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>Name</code>.
                    </div>

                    <textarea class="form-control"
                              rows="8"
                              @bind="_jobRolesContent"
                              placeholder="Name"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import Employees</strong>
                    <span class="badge text-bg-light">Employees</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>Matricola;FullName;Email;OrgUnit;JobRole;IsActive</code>.
                    </div>

                    <textarea class="form-control"
                              rows="8"
                              @bind="_employeesContent"
                              placeholder="Matricola;FullName;Email;OrgUnit;JobRole;IsActive"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import Identity Links</strong>
                    <span class="badge text-bg-light">EmployeeUsers</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>Matricola;UserName;Email;MatchMode</code>.
                        <br />
                        <span>MatchMode: Auto, UserName, Email.</span>
                    </div>

                    <textarea class="form-control"
                              rows="8"
                              @bind="_identityLinksContent"
                              placeholder="Matricola;UserName;Email;MatchMode"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import User Roles</strong>
                    <span class="badge text-bg-light">IdentityRoles</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>UserName;Email;Matricola;Roles;Mode</code>.
                        <br />
                        <span>Roles separati con <code>|</code>. Mode: Add, Replace.</span>
                    </div>

                    <textarea class="form-control"
                              rows="8"
                              @bind="_userRolesContent"
                              placeholder="UserName;Email;Matricola;Roles;Mode"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import participants</strong>
                    <span class="badge text-bg-light">CycleParticipants</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>Cycle;EmployeeMatricola;PhaseCode;Status</code>.
                        <br />
                        <span>Cycle puo essere nome ciclo o Guid. PhaseCode puo essere vuoto o <code>-</code>. Status: Active, Completed, Excluded.</span>
                    </div>

                    <textarea class="form-control"
                              rows="10"
                              @bind="_participantsContent"
                              placeholder="Cycle;EmployeeMatricola;PhaseCode;Status"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import manager relations</strong>
                    <span class="badge text-bg-light">EmployeeManagers</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>EmployeeMatricola;ManagerMatricola;RelationType;IsPrimary;StartDate;EndDate</code>.
                        <br />
                        <span>RelationType: Line, Functional, Project, Hr. Date: yyyy-MM-dd oppure dd/MM/yyyy.</span>
                    </div>

                    <textarea class="form-control"
                              rows="10"
                              @bind="_managerRelationsContent"
                              placeholder="EmployeeMatricola;ManagerMatricola;RelationType;IsPrimary;StartDate;EndDate"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import goal assignments</strong>
                    <span class="badge text-bg-light">GoalAssignments</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>Cycle;EmployeeMatricola;Goal;Weight;TargetValue;StartDate;DueDate;Status</code>.
                        <br />
                        <span>Goal puo essere titolo univoco o Guid. Status: Draft, Approved, InProgress, Closed.</span>
                    </div>

                    <textarea class="form-control"
                              rows="10"
                              @bind="_goalAssignmentsContent"
                              placeholder="Cycle;EmployeeMatricola;Goal;Weight;TargetValue;StartDate;DueDate;Status"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import competency catalog</strong>
                    <span class="badge text-bg-light">Competencies</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>Code;Name;Description;IsActive</code>.
                    </div>

                    <textarea class="form-control"
                              rows="10"
                              @bind="_competenciesContent"
                              placeholder="Code;Name;Description;IsActive"></textarea>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Import competency models</strong>
                    <span class="badge text-bg-light">CompetencyModels</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        Formato: <code>ModelName;ScaleType;MinScore;MaxScore;CompetencyCode;Weight;IsRequired</code>.
                        <br />
                        <span>CompetencyCode puo essere vuoto per creare/aggiornare solo il model. I model gia usati da assessment non vengono modificati.</span>
                    </div>

                    <textarea class="form-control"
                              rows="10"
                              @bind="_competencyModelsContent"
                              placeholder="ModelName;ScaleType;MinScore;MaxScore;CompetencyCode;Weight;IsRequired"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>Commit import</strong>
            <span class="badge text-bg-light">no partial save</span>
        </div>
        <div class="card-body">
            <div class="form-check mb-3">
                <input type="checkbox" class="form-check-input" @bind="_updateExisting" />
                <label class="form-check-label">Aggiorna righe esistenti se trovate</label>
            </div>

            <button class="btn btn-primary"
                    @onclick="ImportAsync"
                    disabled="@(_importing || BothContentsAreEmpty())">
                @if (_importing)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Importa setup performance
            </button>

            @if (_result is not null)
            {
                <div class="mt-4">
                    <div class="@(_result.HasErrors ? "alert alert-warning" : "alert alert-success")">
                        @if (_result.HasErrors)
                        {
                            <span>Import bloccato: correggi gli errori e riprova. Nessuna riga e stata salvata.</span>
                        }
                        else
                        {
                            <span>
                                Import completato.
                                OrgUnits @_result.CreatedOrgUnits/@_result.UpdatedOrgUnits,
                                JobRoles @_result.CreatedJobRoles/@_result.UpdatedJobRoles,
                                Employees @_result.CreatedEmployees/@_result.UpdatedEmployees,
                                Identity links @_result.LinkedEmployees/@_result.RelinkedEmployees,
                                User roles @_result.ProcessedUserRoles/@_result.AddedUserRoleAssignments/@_result.RemovedUserRoleAssignments,
                                Participants @_result.CreatedParticipants/@_result.UpdatedParticipants,
                                Manager relations @_result.CreatedManagerRelations/@_result.UpdatedManagerRelations,
                                Goal assignments @_result.CreatedGoalAssignments/@_result.UpdatedGoalAssignments,
                                Competencies @_result.CreatedCompetencies/@_result.UpdatedCompetencies,
                                Models @_result.CreatedCompetencyModels/@_result.UpdatedCompetencyModels,
                                Model items @_result.CreatedCompetencyModelItems/@_result.UpdatedCompetencyModelItems.
                            </span>
                        }
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Sezione</th>
                                    <th>Riga</th>
                                    <th>Chiave</th>
                                    <th>Status</th>
                                    <th>Messaggio</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _result.Rows)
                                {
                                    <tr class="@(row.Status == "Error" ? "table-warning" : null)">
                                        <td>@row.Section</td>
                                        <td>@row.RowNumber</td>
                                        <td>@row.Key</td>
                                        <td>@row.Status</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.Message) ? "-" : row.Message)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool _importing;
    private bool _updateExisting = true;
    private string? _orgUnitsContent;
    private string? _jobRolesContent;
    private string? _employeesContent;
    private string? _identityLinksContent;
    private string? _userRolesContent;
    private string? _participantsContent;
    private string? _managerRelationsContent;
    private string? _goalAssignmentsContent;
    private string? _competenciesContent;
    private string? _competencyModelsContent;
    private string? _error;
    private string? _successMessage;
    private PerformanceSetupImportResultDto? _result;

    private async Task ImportAsync()
    {
        _importing = true;
        _error = null;
        _successMessage = null;
        _result = null;

        try
        {
            _result = await PerformanceSetupImportAppService.ImportAsync(new ImportPerformanceSetupInput
            {
                OrgUnitsContent = _orgUnitsContent,
                JobRolesContent = _jobRolesContent,
                EmployeesContent = _employeesContent,
                IdentityLinksContent = _identityLinksContent,
                UserRolesContent = _userRolesContent,
                ParticipantsContent = _participantsContent,
                ManagerRelationsContent = _managerRelationsContent,
                GoalAssignmentsContent = _goalAssignmentsContent,
                CompetenciesContent = _competenciesContent,
                CompetencyModelsContent = _competencyModelsContent,
                UpdateExisting = _updateExisting
            });

            if (!_result.HasErrors)
            {
                _successMessage = "Import setup performance completato correttamente.";
            }
        }
        catch (Exception ex)
        {
            _error = UiErrorMessage.From(ex);
        }
        finally
        {
            _importing = false;
        }
    }

    private bool BothContentsAreEmpty()
        => string.IsNullOrWhiteSpace(_orgUnitsContent) &&
           string.IsNullOrWhiteSpace(_jobRolesContent) &&
           string.IsNullOrWhiteSpace(_employeesContent) &&
           string.IsNullOrWhiteSpace(_identityLinksContent) &&
           string.IsNullOrWhiteSpace(_userRolesContent) &&
           string.IsNullOrWhiteSpace(_participantsContent) &&
           string.IsNullOrWhiteSpace(_managerRelationsContent) &&
           string.IsNullOrWhiteSpace(_goalAssignmentsContent) &&
           string.IsNullOrWhiteSpace(_competenciesContent) &&
           string.IsNullOrWhiteSpace(_competencyModelsContent);
}
