@page "/admin/readiness"
@attribute [Authorize(Roles = SuccessFactorRoles.Admin)]
@using SuccessFactor.Admin
@inject IProductionReadinessAppService ProductionReadinessAppService

<PageTitle>Production Readiness</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Production Readiness</h2>
            <div class="text-muted">Cruscotto pre-deploy read-only per la prima tranche deployabile.</div>
        </div>

        <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Aggiorna
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">@_error</div>
    }

    @if (_loading && _data is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento readiness...</span>
        </div>
    }
    else if (_data is not null)
    {
        <div class="@GetSummaryAlertClass()">
            <strong>Esito readiness:</strong>
            @_data.ErrorCount errori, @_data.WarningCount warning.
            @if (_data.ErrorCount == 0)
            {
                <span> La tranche e pronta per smoke test manuale e deploy rehearsal.</span>
            }
            else
            {
                <span> Correggere gli errori prima del deploy rehearsal.</span>
            }
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="small text-muted">Employee attivi</div>
                        <div class="fs-4 fw-semibold">@_data.EmployeeCount</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="small text-muted">User link</div>
                        <div class="fs-4 fw-semibold">@_data.LinkedEmployeeCount</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="small text-muted">Cicli attivi</div>
                        <div class="fs-4 fw-semibold">@_data.ActiveCycleCount</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="small text-muted">Participants attivi</div>
                        <div class="fs-4 fw-semibold">@_data.ActiveParticipantCount</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="small text-muted">Manager relations</div>
                        <div class="fs-4 fw-semibold">@_data.ActiveManagerRelationCount</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="small text-muted">Workflow policies</div>
                        <div class="fs-4 fw-semibold">@_data.WorkflowFieldPolicyCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong>Controlli readiness</strong>
                <span class="badge text-bg-light">@_data.Checks.Count</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Area</th>
                                <th>Check</th>
                                <th>Status</th>
                                <th>Messaggio</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _data.Checks)
                            {
                                <tr class="@GetRowClass(item.Status)">
                                    <td>@item.Area</td>
                                    <td class="fw-semibold">@item.Check</td>
                                    <td><span class="@GetBadgeClass(item.Status)">@item.Status</span></td>
                                    <td>@item.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading;
    private string? _error;
    private ProductionReadinessDto? _data;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await ProductionReadinessAppService.GetAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetSummaryAlertClass()
        => _data?.ErrorCount > 0 ? "alert alert-danger mb-4" : _data?.WarningCount > 0 ? "alert alert-warning mb-4" : "alert alert-success mb-4";

    private static string GetBadgeClass(string status)
        => status switch
        {
            "Ok" => "badge text-bg-success",
            "Warning" => "badge text-bg-warning",
            "Error" => "badge text-bg-danger",
            _ => "badge text-bg-light"
        };

    private static string? GetRowClass(string status)
        => status switch
        {
            "Warning" => "table-warning",
            "Error" => "table-danger",
            _ => null
        };
}
