@page "/admin/workflow"
@attribute [Authorize(Roles = SuccessFactorRoles.Admin)]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using SuccessFactor.Admin
@using SuccessFactor.Process
@using SuccessFactor.Workflow
@inject IWorkflowAdminAppService WorkflowAdminAppService
@inject NavigationManager NavigationManager

<PageTitle>Workflow Admin</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Workflow Admin</h2>
            <div class="text-muted">Crea template, definisci fasi e transizioni, poi configura permessi e field policy.</div>

            @if (_data is not null && _data.SelectedTemplateId.HasValue)
            {
                <div class="text-muted mt-1">
                    template: <strong>@_data.SelectedTemplateName</strong>
                    <span class="mx-2">-</span>
                    versione: @_data.SelectedTemplateVersion
                    <span class="mx-2">-</span>
                    fase: <strong>@(_data.SelectedPhaseCode ?? "-")</strong>
                </div>
            }
        </div>

        <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Aggiorna
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">@_successMessage</div>
    }

    @if (_loading && _data is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento configurazione workflow...</span>
        </div>
    }
    else if (_data is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Selezione</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Template</label>
                            <select class="form-select"
                                    value="@(_selectedTemplateId?.ToString() ?? string.Empty)"
                                    @onchange="OnTemplateChangedAsync">
                                @if (_data.Templates.Count == 0)
                                {
                                    <option value="">Nessun template disponibile</option>
                                }
                                else
                                {
                                    @foreach (var template in _data.Templates)
                                    {
                                        <option value="@template.TemplateId">@template.TemplateName (v@template.Version)</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fase</label>
                            <select class="form-select"
                                    value="@(_selectedPhaseId?.ToString() ?? string.Empty)"
                                    @onchange="OnPhaseChangedAsync"
                                    disabled="@(_data.Phases.Count == 0)">
                                @if (_data.Phases.Count == 0)
                                {
                                    <option value="">Nessuna fase disponibile</option>
                                }
                                else
                                {
                                    @foreach (var phase in _data.Phases)
                                    {
                                        <option value="@phase.PhaseId">@phase.PhaseOrder - @phase.PhaseCode - @phase.PhaseName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="small text-muted">
                            template: @_data.Templates.Count
                            <br />
                            fasi: @_data.Phases.Count
                            <br />
                            transizioni: @_data.Transitions.Count
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Contesto</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Template</div>
                                <div class="fw-semibold">@(_data.SelectedTemplateName ?? "-")</div>
                            </div>
                            <div class="col-12 col-md-2">
                                <div class="text-muted small">Versione</div>
                                <div>@(_data.SelectedTemplateVersion?.ToString() ?? "-")</div>
                            </div>
                            <div class="col-12 col-md-2">
                                <div class="text-muted small">Default</div>
                                <div>@YesNo(_data.SelectedTemplateIsDefault)</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Fase</div>
                                <div>@(string.IsNullOrWhiteSpace(_data.SelectedPhaseCode) ? "-" : $"{_data.SelectedPhaseCode} - {_data.SelectedPhaseName}")</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Role permissions</div>
                                <div>@_data.RolePermissions.Count</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Field policies</div>
                                <div>@_data.FieldPolicies.Count</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Transizioni</div>
                                <div>@_data.Transitions.Count</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong>Import massivo workflow</strong>
                <span class="badge text-bg-light">no partial save</span>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    Usa l'import per creare o aggiornare template, fasi, transizioni, role permissions e field policies in modo coordinato.
                    Se anche una sola riga e in errore, non viene salvato nulla.
                </div>

                <div class="row g-3">
                    <div class="col-12 col-xxl-6">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold mb-2">Templates</div>
                            <div class="small text-muted mb-2">Formato: <code>TemplateName;Version;IsDefault</code></div>
                            <textarea class="form-control"
                                      rows="6"
                                      @bind="_workflowTemplatesContent"
                                      placeholder="Performance Annuale;1;true"></textarea>
                        </div>
                    </div>

                    <div class="col-12 col-xxl-6">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold mb-2">Phases</div>
                            <div class="small text-muted mb-2">Formato: <code>TemplateName;Version;PhaseCode;PhaseName;PhaseOrder;IsTerminal;StartRule;EndRule</code></div>
                            <textarea class="form-control"
                                      rows="6"
                                      @bind="_workflowPhasesContent"
                                      placeholder="Performance Annuale;1;SELF;Autovalutazione;1;false;;"></textarea>
                        </div>
                    </div>

                    <div class="col-12 col-xxl-6">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold mb-2">Transitions</div>
                            <div class="small text-muted mb-2">Formato: <code>TemplateName;Version;FromPhaseCode;ToPhaseCode;ConditionExpr</code></div>
                            <textarea class="form-control"
                                      rows="6"
                                      @bind="_workflowTransitionsContent"
                                      placeholder="Performance Annuale;1;SELF;MGR;"></textarea>
                        </div>
                    </div>

                    <div class="col-12 col-xxl-6">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold mb-2">Role permissions</div>
                            <div class="small text-muted mb-2">Formato: <code>TemplateName;Version;PhaseCode;RoleCode;CanView;CanEdit;CanSubmit;CanAdvance;ConditionExpr</code></div>
                            <textarea class="form-control"
                                      rows="6"
                                      @bind="_workflowRolePermissionsContent"
                                      placeholder="Performance Annuale;1;SELF;Dipendente;true;true;true;true;"></textarea>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold mb-2">Field policies</div>
                            <div class="small text-muted mb-2">Formato: <code>TemplateName;Version;PhaseCode;FieldKey;RoleCode;Access;IsRequired;ConditionExpr</code></div>
                            <textarea class="form-control"
                                      rows="6"
                                      @bind="_workflowFieldPoliciesContent"
                                      placeholder="Performance Annuale;1;SELF;Goals.ProgressPercent;Dipendente;Read;false;"></textarea>
                        </div>
                    </div>
                </div>

                <div class="form-check mt-3">
                    <input type="checkbox" class="form-check-input" @bind="_workflowImportUpdateExisting" />
                    <label class="form-check-label">Aggiorna righe esistenti se trovate</label>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-primary"
                            @onclick="ImportWorkflowAsync"
                            disabled="@(_importingWorkflow || WorkflowImportContentsAreEmpty())">
                        @if (_importingWorkflow)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Importa workflow
                    </button>
                </div>

                @if (_workflowImportResult is not null)
                {
                    <div class="mt-4">
                        <div class="@(_workflowImportResult.HasErrors ? "alert alert-warning" : "alert alert-success")">
                            @if (_workflowImportResult.HasErrors)
                            {
                                <span>Import bloccato: correggi gli errori e riprova. Nessuna riga e stata salvata.</span>
                            }
                            else
                            {
                                <span>
                                    Import completato.
                                    Templates @_workflowImportResult.CreatedTemplates/@_workflowImportResult.UpdatedTemplates,
                                    Phases @_workflowImportResult.CreatedPhases/@_workflowImportResult.UpdatedPhases,
                                    Transitions @_workflowImportResult.CreatedTransitions/@_workflowImportResult.UpdatedTransitions,
                                    Role permissions @_workflowImportResult.CreatedRolePermissions/@_workflowImportResult.UpdatedRolePermissions,
                                    Field policies @_workflowImportResult.CreatedFieldPolicies/@_workflowImportResult.UpdatedFieldPolicies.
                                </span>
                            }
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Sezione</th>
                                        <th>Riga</th>
                                        <th>Chiave</th>
                                        <th>Status</th>
                                        <th>Messaggio</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _workflowImportResult.Rows)
                                    {
                                        <tr class="@(row.Status == "Error" ? "table-warning" : null)">
                                            <td>@row.Section</td>
                                            <td>@row.RowNumber</td>
                                            <td>@row.Key</td>
                                            <td>@row.Status</td>
                                            <td>@(string.IsNullOrWhiteSpace(row.Message) ? "-" : row.Message)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-xxl-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <strong>Template</strong>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ResetTemplateForm">Nuovo</button>
                    </div>
                    <div class="card-body">
                        <EditForm Model="_templateForm" OnValidSubmit="SaveTemplateAsync">
                            <DataAnnotationsValidator />
                            <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                            <div class="row g-3 mb-3">
                                <div class="col-12">
                                    <label class="form-label">Nome template</label>
                                    <InputText class="form-control" @bind-Value="_templateForm.Name" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Versione</label>
                                    <InputNumber class="form-control" @bind-Value="_templateForm.Version" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Default</label>
                                    <InputCheckbox class="form-check-input d-block mt-2" @bind-Value="_templateForm.IsDefault" />
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mb-4">
                                <button class="btn btn-primary" type="submit" disabled="@_savingTemplate">Salva template</button>
                                @if (_templateForm.Id.HasValue)
                                {
                                    <button class="btn btn-outline-danger" type="button" @onclick="DeleteTemplateAsync" disabled="@_savingTemplate">Elimina</button>
                                }
                            </div>
                        </EditForm>

                        @if (_data.Templates.Count == 0)
                        {
                            <div class="text-muted">Nessun template configurato.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Nome</th>
                                            <th>Versione</th>
                                            <th>Default</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in _data.Templates)
                                        {
                                            <tr class="@(item.TemplateId == _selectedTemplateId ? "table-active" : null)">
                                                <td class="fw-semibold">@item.TemplateName</td>
                                                <td>@item.Version</td>
                                                <td>@YesNo(item.IsDefault)</td>
                                                <td class="text-end">
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditTemplate(item)">Modifica</button>
                                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectTemplate(item.TemplateId)">Apri</button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xxl-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <strong>Fasi</strong>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ResetPhaseForm" disabled="@(!_selectedTemplateId.HasValue)">Nuova</button>
                    </div>
                    <div class="card-body">
                        @if (!_selectedTemplateId.HasValue)
                        {
                            <div class="text-muted">Seleziona o crea prima un template.</div>
                        }
                        else
                        {
                            <EditForm Model="_phaseForm" OnValidSubmit="SavePhaseAsync">
                                <DataAnnotationsValidator />
                                <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">Code</label>
                                        <InputText class="form-control" @bind-Value="_phaseForm.Code" />
                                    </div>
                                    <div class="col-12 col-md-8">
                                        <label class="form-label">Nome fase</label>
                                        <InputText class="form-control" @bind-Value="_phaseForm.Name" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">Ordine</label>
                                        <InputNumber class="form-control" @bind-Value="_phaseForm.PhaseOrder" />
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">Terminale</label>
                                        <InputCheckbox class="form-check-input d-block mt-2" @bind-Value="_phaseForm.IsTerminal" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">StartRule</label>
                                        <InputText class="form-control" @bind-Value="_phaseForm.StartRule" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">EndRule</label>
                                        <InputText class="form-control" @bind-Value="_phaseForm.EndRule" />
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-4">
                                    <button class="btn btn-primary" type="submit" disabled="@_savingPhase">Salva fase</button>
                                    @if (_phaseForm.Id.HasValue)
                                    {
                                        <button class="btn btn-outline-danger" type="button" @onclick="DeletePhaseAsync" disabled="@_savingPhase">Elimina</button>
                                    }
                                </div>
                            </EditForm>

                            @if (_data.Phases.Count == 0)
                            {
                                <div class="text-muted">Nessuna fase configurata.</div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Ordine</th>
                                                <th>Code</th>
                                                <th>Nome</th>
                                                <th>Terminale</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in _data.Phases)
                                            {
                                                <tr class="@(item.PhaseId == _selectedPhaseId ? "table-active" : null)">
                                                    <td>@item.PhaseOrder</td>
                                                    <td class="fw-semibold">@item.PhaseCode</td>
                                                    <td>@item.PhaseName</td>
                                                    <td>@YesNo(item.IsTerminal)</td>
                                                    <td class="text-end">
                                                        <div class="d-flex justify-content-end gap-2">
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditPhase(item)">Modifica</button>
                                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectPhase(item.PhaseId)">Apri</button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xxl-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <strong>Transizioni</strong>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ResetTransitionForm" disabled="@(!_selectedTemplateId.HasValue || _data.Phases.Count < 2)">Nuova</button>
                    </div>
                    <div class="card-body">
                        @if (!_selectedTemplateId.HasValue)
                        {
                            <div class="text-muted">Seleziona o crea prima un template.</div>
                        }
                        else if (_data.Phases.Count < 2)
                        {
                            <div class="text-muted">Servono almeno due fasi per creare una transizione.</div>
                        }
                        else
                        {
                            <EditForm Model="_transitionForm" OnValidSubmit="SaveTransitionAsync">
                                <DataAnnotationsValidator />
                                <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">Da fase</label>
                                        <InputSelect class="form-select" @bind-Value="_transitionForm.FromPhaseId">
                                            <option value="">Seleziona fase origine</option>
                                            @foreach (var phase in _data.Phases)
                                            {
                                                <option value="@phase.PhaseId">@phase.PhaseOrder - @phase.PhaseCode</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label class="form-label">A fase</label>
                                        <InputSelect class="form-select" @bind-Value="_transitionForm.ToPhaseId">
                                            <option value="">Seleziona fase destinazione</option>
                                            @foreach (var phase in _data.Phases)
                                            {
                                                <option value="@phase.PhaseId">@phase.PhaseOrder - @phase.PhaseCode</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">ConditionExpr</label>
                                        <InputText class="form-control" @bind-Value="_transitionForm.ConditionExpr" />
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-4">
                                    <button class="btn btn-primary" type="submit" disabled="@_savingTransition">Salva transizione</button>
                                    @if (_transitionForm.Id.HasValue)
                                    {
                                        <button class="btn btn-outline-danger" type="button" @onclick="DeleteTransitionAsync" disabled="@_savingTransition">Elimina</button>
                                    }
                                </div>
                            </EditForm>
                        }

                        @if (_data.Transitions.Count == 0)
                        {
                            <div class="text-muted">Nessuna transizione configurata.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Da</th>
                                            <th>A</th>
                                            <th>Condition</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in _data.Transitions)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@item.FromPhaseCode</td>
                                                <td>@item.ToPhaseCode</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.ConditionExpr) ? "-" : item.ConditionExpr)</td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditTransition(item)">Modifica</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (_data.SelectedTemplateId.HasValue && _data.SelectedPhaseId.HasValue)
        {
            <div class="row g-3">
                <div class="col-12 col-xxl-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-white">
                            <strong>Role permissions</strong>
                        </div>
                        <div class="card-body">
                            <EditForm Model="_rolePermissionForm" OnValidSubmit="SaveRolePermissionAsync">
                                <DataAnnotationsValidator />
                                <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">RoleCode</label>
                                        <InputText class="form-control" @bind-Value="_rolePermissionForm.RoleCode" />
                                    </div>
                                    <div class="col-6 col-md-2">
                                        <label class="form-label">View</label>
                                        <InputCheckbox class="form-check-input d-block mt-2" @bind-Value="_rolePermissionForm.CanView" />
                                    </div>
                                    <div class="col-6 col-md-2">
                                        <label class="form-label">Edit</label>
                                        <InputCheckbox class="form-check-input d-block mt-2" @bind-Value="_rolePermissionForm.CanEdit" />
                                    </div>
                                    <div class="col-6 col-md-2">
                                        <label class="form-label">Submit</label>
                                        <InputCheckbox class="form-check-input d-block mt-2" @bind-Value="_rolePermissionForm.CanSubmit" />
                                    </div>
                                    <div class="col-6 col-md-2">
                                        <label class="form-label">Advance</label>
                                        <InputCheckbox class="form-check-input d-block mt-2" @bind-Value="_rolePermissionForm.CanAdvance" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">ConditionExpr</label>
                                        <InputText class="form-control" @bind-Value="_rolePermissionForm.ConditionExpr" />
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-4">
                                    <button class="btn btn-primary" type="submit" disabled="@_savingRolePermission">Salva permission</button>
                                    <button class="btn btn-outline-secondary" type="button" @onclick="ResetRolePermissionForm">Nuova</button>
                                </div>
                            </EditForm>

                            @if (_data.RolePermissions.Count == 0)
                            {
                                <div class="text-muted">Nessuna role permission configurata.</div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Role</th>
                                                <th>View</th>
                                                <th>Edit</th>
                                                <th>Submit</th>
                                                <th>Advance</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in _data.RolePermissions)
                                            {
                                                <tr>
                                                    <td class="fw-semibold">@item.RoleCode</td>
                                                    <td>@YesNo(item.CanView)</td>
                                                    <td>@YesNo(item.CanEdit)</td>
                                                    <td>@YesNo(item.CanSubmit)</td>
                                                    <td>@YesNo(item.CanAdvance)</td>
                                                    <td class="text-end">
                                                        <div class="d-flex justify-content-end gap-2">
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditRolePermission(item)">Modifica</button>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRolePermissionAsync(item.Id)">Elimina</button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xxl-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-white">
                            <strong>Field policies</strong>
                        </div>
                        <div class="card-body">
                            <EditForm Model="_fieldPolicyForm" OnValidSubmit="SaveFieldPolicyAsync">
                                <DataAnnotationsValidator />
                                <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-md-4">
                                        <label class="form-label">FieldKey</label>
                                        <InputText class="form-control" @bind-Value="_fieldPolicyForm.FieldKey" />
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <label class="form-label">RoleCode</label>
                                        <InputText class="form-control" @bind-Value="_fieldPolicyForm.RoleCode" />
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <label class="form-label">Access</label>
                                        <InputSelect class="form-select" @bind-Value="_fieldPolicyForm.Access">
                                            <option value="Hidden">Hidden</option>
                                            <option value="Read">Read</option>
                                            <option value="Edit">Edit</option>
                                        </InputSelect>
                                    </div>
                                    <div class="col-12 col-md-2">
                                        <label class="form-label">Required</label>
                                        <InputCheckbox class="form-check-input d-block mt-2" @bind-Value="_fieldPolicyForm.IsRequired" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">ConditionExpr</label>
                                        <InputText class="form-control" @bind-Value="_fieldPolicyForm.ConditionExpr" />
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-4">
                                    <button class="btn btn-primary" type="submit" disabled="@_savingFieldPolicy">Salva policy</button>
                                    <button class="btn btn-outline-secondary" type="button" @onclick="ResetFieldPolicyForm">Nuova</button>
                                </div>
                            </EditForm>

                            @if (_data.FieldPolicies.Count == 0)
                            {
                                <div class="text-muted">Nessuna field policy configurata.</div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>FieldKey</th>
                                                <th>Role</th>
                                                <th>Access</th>
                                                <th>Required</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in _data.FieldPolicies)
                                            {
                                                <tr>
                                                    <td class="fw-semibold">@item.FieldKey</td>
                                                    <td>@item.RoleCode</td>
                                                    <td>@item.Access</td>
                                                    <td>@YesNo(item.IsRequired)</td>
                                                    <td class="text-end">
                                                        <div class="d-flex justify-content-end gap-2">
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditFieldPolicy(item)">Modifica</button>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFieldPolicyAsync(item.Id)">Elimina</button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "templateId")]
    public Guid? TemplateId { get; set; }

    [SupplyParameterFromQuery(Name = "phaseId")]
    public Guid? PhaseId { get; set; }

    private bool _loading;
    private bool _savingTemplate;
    private bool _savingPhase;
    private bool _savingTransition;
    private bool _savingRolePermission;
    private bool _savingFieldPolicy;
    private bool _importingWorkflow;
    private string? _error;
    private string? _successMessage;
    private WorkflowAdminDto? _data;
    private WorkflowImportResultDto? _workflowImportResult;
    private Guid? _selectedTemplateId;
    private Guid? _selectedPhaseId;
    private bool _workflowImportUpdateExisting = true;
    private string? _workflowTemplatesContent;
    private string? _workflowPhasesContent;
    private string? _workflowTransitionsContent;
    private string? _workflowRolePermissionsContent;
    private string? _workflowFieldPoliciesContent;
    private TemplateFormModel _templateForm = new();
    private PhaseFormModel _phaseForm = new();
    private TransitionFormModel _transitionForm = new();
    private RolePermissionFormModel _rolePermissionForm = new();
    private FieldPolicyFormModel _fieldPolicyForm = new();

    protected override async Task OnParametersSetAsync()
    {
        _selectedTemplateId = TemplateId;
        _selectedPhaseId = PhaseId;
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await WorkflowAdminAppService.GetAsync(new GetWorkflowAdminInput
            {
                TemplateId = _selectedTemplateId,
                PhaseId = _selectedPhaseId
            });

            _selectedTemplateId = _data.SelectedTemplateId;
            _selectedPhaseId = _data.SelectedPhaseId;

            ResetTemplateForm();
            ResetPhaseForm();
            ResetTransitionForm();
            ResetRolePermissionForm();
            ResetFieldPolicyForm();
        }
        catch (Exception ex)
        {
            _error = UiErrorMessage.From(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnTemplateChangedAsync(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var templateId))
        {
            NavigationManager.NavigateTo(BuildUrl(null, null));
            return Task.CompletedTask;
        }

        _selectedTemplateId = templateId;
        _selectedPhaseId = null;
        NavigationManager.NavigateTo(BuildUrl(_selectedTemplateId, null));
        return Task.CompletedTask;
    }

    private Task OnPhaseChangedAsync(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var phaseId))
        {
            NavigationManager.NavigateTo(BuildUrl(_selectedTemplateId, null));
            return Task.CompletedTask;
        }

        _selectedPhaseId = phaseId;
        NavigationManager.NavigateTo(BuildUrl(_selectedTemplateId, _selectedPhaseId));
        return Task.CompletedTask;
    }

    private void SelectTemplate(Guid templateId)
    {
        NavigationManager.NavigateTo(BuildUrl(templateId, null));
    }

    private void SelectPhase(Guid phaseId)
    {
        NavigationManager.NavigateTo(BuildUrl(_selectedTemplateId, phaseId));
    }

    private async Task SaveTemplateAsync()
    {
        _savingTemplate = true;
        _error = null;
        _successMessage = null;

        try
        {
            var saved = await WorkflowAdminAppService.SaveTemplateAsync(_templateForm.Id, new CreateUpdateProcessTemplateDto
            {
                Name = _templateForm.Name ?? string.Empty,
                Version = _templateForm.Version,
                IsDefault = _templateForm.IsDefault
            });

            _successMessage = "Template salvato correttamente.";
            NavigationManager.NavigateTo(BuildUrl(saved.TemplateId, null));
        }
        catch (Exception ex)
        {
            _error = UiErrorMessage.From(ex);
        }
        finally
        {
            _savingTemplate = false;
        }
    }

    private async Task DeleteTemplateAsync()
    {
        if (!_templateForm.Id.HasValue)
        {
            return;
        }

        _savingTemplate = true;
        _error = null;
        _successMessage = null;

        try
        {
            await WorkflowAdminAppService.DeleteTemplateAsync(_templateForm.Id.Value);
            _successMessage = "Template eliminato correttamente.";
            NavigationManager.NavigateTo(BuildUrl(null, null));
        }
        catch (Exception ex)
        {
            _error = UiErrorMessage.From(ex);
        }
        finally
        {
            _savingTemplate = false;
        }
    }

