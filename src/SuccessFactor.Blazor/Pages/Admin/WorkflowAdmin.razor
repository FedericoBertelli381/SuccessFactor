    private async Task ImportWorkflowAsync()
    {
        _importingWorkflow = true;
        _error = null;
        _successMessage = null;
        _workflowImportResult = null;

        try
        {
            _workflowImportResult = await WorkflowAdminAppService.ImportAsync(new ImportWorkflowSetupInput
            {
                TemplatesContent = _workflowTemplatesContent,
                PhasesContent = _workflowPhasesContent,
                TransitionsContent = _workflowTransitionsContent,
                RolePermissionsContent = _workflowRolePermissionsContent,
                FieldPoliciesContent = _workflowFieldPoliciesContent,
                UpdateExisting = _workflowImportUpdateExisting
            });

            if (!_workflowImportResult.HasErrors)
            {
                _successMessage = "Import workflow completato correttamente.";
                await LoadAsync();
            }
