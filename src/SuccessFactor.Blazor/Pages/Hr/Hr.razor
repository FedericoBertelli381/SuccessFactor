@page "/hr"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using SuccessFactor.Hr
@using SuccessFactor.My.Dtos
@inject IHrDashboardAppService HrDashboardAppService
@inject NavigationManager NavigationManager

<PageTitle>HR Dashboard</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">HR Dashboard</h2>

            @if (_dashboard is not null && _dashboard.SelectedCycleId.HasValue)
            {
                <div class="text-muted">
                    ciclo: @_dashboard.SelectedCycleName
                    <span class="mx-2">•</span>
                    status: <strong>@_dashboard.SelectedCycleStatus</strong>
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary"
                    @onclick="ReloadAsync"
                    disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Aggiorna
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">
            @_error
        </div>
    }
    else if (_loading && _dashboard is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento HR dashboard...</span>
        </div>
    }
    else if (_dashboard is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Selezione ciclo</strong>
                    </div>
                    <div class="card-body">
                        @if (_dashboard.Cycles.Count == 0)
                        {
                            <div class="text-muted">Nessun ciclo disponibile.</div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Ciclo</label>
                                <select class="form-select"
                                        value="@(_selectedCycleId?.ToString() ?? string.Empty)"
                                        @onchange="OnCycleChangedAsync">
                                    @foreach (var cycle in _dashboard.Cycles)
                                    {
                                        <option value="@cycle.CycleId">@cycle.CycleName (@cycle.CycleStatus)</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Dipendente</label>
                                <select class="form-select"
                                        value="@(_selectedEmployeeId?.ToString() ?? string.Empty)"
                                        @onchange="OnEmployeeChangedAsync"
                                        disabled="@(_dashboard.Participants.Count == 0)">
                                    @if (_dashboard.Participants.Count == 0)
                                    {
                                        <option value="">Nessun dipendente disponibile</option>
                                    }
                                    else
                                    {
                                        @foreach (var participant in _dashboard.Participants)
                                        {
                                            <option value="@participant.EmployeeId">@participant.FullName (@participant.Matricola)</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="small text-muted">
                                cicli disponibili: @_dashboard.Cycles.Count
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Riepilogo partecipanti</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Totali</div>
                                <div class="fw-semibold">@_dashboard.TotalParticipants</div>
                            </div>
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Active</div>
                                <div>@_dashboard.ActiveParticipants</div>
                            </div>
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Completed</div>
                                <div>@_dashboard.CompletedParticipants</div>
                            </div>
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Fase target</div>
                                <div>@(_dashboard.SelectedEmployeePhaseCode ?? "-")</div>
                            </div>
                        </div>

                        @if (_dashboard.SelectedEmployeeId.HasValue)
                        {
                            <div class="mt-3 pt-3 border-top">
                                <div class="text-muted small">Target selezionato</div>
                                <div class="fw-semibold">@_dashboard.SelectedEmployeeName</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>Partecipanti del ciclo</strong>
            </div>
            <div class="card-body">
                @if (_dashboard.Participants.Count == 0)
                {
                    <div class="text-muted">Nessun partecipante nel ciclo selezionato.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Dipendente</th>
                                    <th>Matricola</th>
                                    <th>Email</th>
                                    <th>Status partecipazione</th>
                                    <th>Fase corrente</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var participant in _dashboard.Participants)
                                {
                                    var rowClass = _dashboard.SelectedEmployeeId == participant.EmployeeId
                                        ? "table-primary"
                                        : string.Empty;

                                    <tr class="@rowClass">
                                        <td class="fw-semibold">@participant.FullName</td>
                                        <td>@participant.Matricola</td>
                                        <td>@(string.IsNullOrWhiteSpace(participant.Email) ? "-" : participant.Email)</td>
                                        <td>
                                            <span class="badge text-bg-light">@participant.ParticipantStatus</span>
                                        </td>
                                        <td>
                                            <div>@(participant.CurrentPhaseCode ?? "-")</div>
                                            <div class="small text-muted">@participant.CurrentPhaseName</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @if (_dashboard.Goals is not null)
        {
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Goals target</strong>
                    <span class="badge text-bg-light">Read only</span>
                </div>
                <div class="card-body">
                    @if (_dashboard.Goals.Items.Count == 0)
                    {
                        <div class="text-muted">Nessun goal assegnato al target nel ciclo selezionato.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Goal</th>
                                        <th>Status</th>
                                        <th>Peso</th>
                                        <th>Target</th>
                                        <th>Due date</th>
                                        <th>Ultimo avanzamento</th>
                                        <th>Ultima nota</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var goal in _dashboard.Goals.Items)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@goal.GoalName</td>
                                            <td>@goal.Status</td>
                                            <td>@goal.Weight</td>
                                            <td>@FormatDecimal(goal.TargetValue)</td>
                                            <td>@FormatDate(goal.DueDate)</td>
                                            <td>
                                                @if (goal.LastProgress is null)
                                                {
                                                    <span>-</span>
                                                }
                                                else
                                                {
                                                    <span>@FormatDecimal(goal.LastProgress.ProgressPercent)%</span>
                                                }
                                            </td>
                                            <td>@(string.IsNullOrWhiteSpace(goal.LastProgress?.Note) ? "-" : goal.LastProgress!.Note)</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => OpenGoalDetail(goal.AssignmentId)">
                                                    Apri detail
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }

        @if (_dashboard.Assessments is not null)
        {
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>Assessments target</strong>
                    <span class="badge text-bg-light">Read only</span>
                </div>
                <div class="card-body">
                    @if (_dashboard.Assessments.Items.Count == 0)
                    {
                        <div class="text-muted">Nessun assessment disponibile per il target nel ciclo selezionato.</div>
                    }
                    else
                    {
                        @foreach (var assessment in _dashboard.Assessments.Items)
                        {
                            <div class="border rounded p-3 mb-3">
                                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <div class="fw-semibold">@assessment.AssessmentType</div>
                                        <div class="small text-muted">
                                            model: @(string.IsNullOrWhiteSpace(assessment.ModelName) ? "-" : assessment.ModelName)
                                            <span class="mx-2">-</span>
                                            status: @assessment.Status
                                        </div>
                                    </div>
                                    <div class="small text-muted text-end">
                                        <div>evaluator: @assessment.EvaluatorEmployeeName</div>
                                        <div>required compilati: @(assessment.RequiredItemsCount - assessment.MissingRequiredCount)/@assessment.RequiredItemsCount</div>
                                    </div>
                                </div>

                                @if (assessment.Items.Count == 0)
                                {
                                    <div class="text-muted">Nessuna competenza nel model associato.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Competenza</th>
                                                    <th>Required</th>
                                                    <th>Weight</th>
                                                    <th>Score</th>
                                                    <th>Commento</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in assessment.Items)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="fw-semibold">@item.CompetencyName</div>
                                                            <div class="small text-muted">@item.CompetencyCode</div>
                                                        </td>
                                                        <td>@(item.IsRequired ? "Si" : "No")</td>
                                                        <td>@FormatDecimal(item.Weight)</td>
                                                        <td>@(item.Score?.ToString() ?? "-")</td>
                                                        <td>@(string.IsNullOrWhiteSpace(item.Comment) ? "-" : item.Comment)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }

                                <div class="d-flex justify-content-end mt-3">
                                    <button class="btn btn-sm btn-outline-secondary"
                                            @onclick="() => OpenAssessmentDetail(assessment.AssessmentId)">
                                        Apri detail
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "cycleId")]
    public Guid? CycleId { get; set; }

    [SupplyParameterFromQuery(Name = "targetEmployeeId")]
    public Guid? TargetEmployeeId { get; set; }

    private bool _loading;
    private string? _error;
    private HrDashboardDto? _dashboard;
    private Guid? _selectedCycleId;
    private Guid? _selectedEmployeeId;

    protected override async Task OnParametersSetAsync()
    {
        _selectedCycleId = CycleId;
        _selectedEmployeeId = TargetEmployeeId;
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _dashboard = await HrDashboardAppService.GetAsync(new GetHrDashboardInput
            {
                CycleId = _selectedCycleId,
                TargetEmployeeId = _selectedEmployeeId
            });

            _selectedCycleId = _dashboard.SelectedCycleId;
            _selectedEmployeeId = _dashboard.SelectedEmployeeId;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnCycleChangedAsync(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var cycleId))
        {
            return Task.CompletedTask;
        }

        _selectedCycleId = cycleId;
        _selectedEmployeeId = null;
        NavigationManager.NavigateTo(BuildHrUrl(_selectedCycleId, null));
        return Task.CompletedTask;
    }

    private Task OnEmployeeChangedAsync(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var employeeId))
        {
            return Task.CompletedTask;
        }

        _selectedEmployeeId = employeeId;
        NavigationManager.NavigateTo(BuildHrUrl(_selectedCycleId, _selectedEmployeeId));
        return Task.CompletedTask;
    }

    private string BuildHrUrl(Guid? cycleId, Guid? employeeId)
    {
        var query = new System.Collections.Generic.Dictionary<string, string?>();

        if (cycleId.HasValue)
        {
            query["cycleId"] = cycleId.Value.ToString();
        }

        if (employeeId.HasValue)
        {
            query["targetEmployeeId"] = employeeId.Value.ToString();
        }

        var tenant = GetCurrentTenantFromUrl();

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            query["__tenant"] = tenant;
        }

        return QueryHelpers.AddQueryString("/hr", query!);
    }

    private void OpenGoalDetail(Guid assignmentId)
    {
        if (!_selectedEmployeeId.HasValue)
        {
            return;
        }

        NavigationManager.NavigateTo(BuildHrDetailUrl($"/hr/goals/{_selectedEmployeeId.Value}/{assignmentId}"));
    }

    private void OpenAssessmentDetail(Guid assessmentId)
    {
        if (!_selectedEmployeeId.HasValue)
        {
            return;
        }

        NavigationManager.NavigateTo(BuildHrDetailUrl($"/hr/assessments/{_selectedEmployeeId.Value}/{assessmentId}"));
    }

    private string BuildHrDetailUrl(string basePath)
    {
        var query = new System.Collections.Generic.Dictionary<string, string?>();

        if (_selectedCycleId.HasValue)
        {
            query["cycleId"] = _selectedCycleId.Value.ToString();
        }

        var tenant = GetCurrentTenantFromUrl();

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            query["__tenant"] = tenant;
        }

        return QueryHelpers.AddQueryString(basePath, query!);
    }

    private string? GetCurrentTenantFromUrl()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("__tenant", out var tenantValues))
        {
            var tenant = tenantValues.ToString();
            return string.IsNullOrWhiteSpace(tenant) ? null : tenant;
        }

        return null;
    }

    private static string FormatDate(DateOnly? value)
    {
        return value?.ToString("dd/MM/yyyy") ?? "-";
    }

    private static string FormatDecimal(decimal? value)
    {
        return value?.ToString("0.##") ?? "-";
    }
}
