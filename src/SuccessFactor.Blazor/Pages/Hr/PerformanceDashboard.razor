@page "/hr/performance-dashboard"
@attribute [Authorize(Roles = SuccessFactorRoles.AdminOrHr)]
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using SuccessFactor.Hr
@inject IPerformanceDashboardAppService PerformanceDashboardAppService
@inject NavigationManager NavigationManager

<PageTitle>Performance Dashboard</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Performance Dashboard</h2>
            @if (_dashboard is not null && _dashboard.SelectedCycleId.HasValue)
            {
                <div class="text-muted">
                    ciclo: @_dashboard.SelectedCycleName
                    <span class="mx-2">-</span>
                    status: <strong>@_dashboard.SelectedCycleStatus</strong>
                </div>
            }
        </div>

        <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Aggiorna
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">@_error</div>
    }
    else if (_loading && _dashboard is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento performance dashboard...</span>
        </div>
    }
    else if (_dashboard is not null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <strong>Selezione ciclo</strong>
            </div>
            <div class="card-body">
                @if (_dashboard.Cycles.Count == 0)
                {
                    <div class="text-muted">Nessun ciclo disponibile.</div>
                }
                else
                {
                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-lg-6">
                            <label class="form-label">Ciclo</label>
                            <select class="form-select"
                                    value="@(_selectedCycleId?.ToString() ?? string.Empty)"
                                    @onchange="OnCycleChangedAsync">
                                @foreach (var cycle in _dashboard.Cycles)
                                {
                                    <option value="@cycle.CycleId">@cycle.CycleName (@cycle.CycleStatus)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-lg-6">
                            <div class="small text-muted">
                                Vista aggregata read-only per HR/direzione: partecipanti, progress, completion, score, OrgUnit e JobRole.
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Participants</div>
                        <div class="fs-4 fw-semibold">@_dashboard.ParticipantCount</div>
                        <div class="small text-muted">@_dashboard.CompletedParticipantCount completed</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Cycle completion</div>
                        <div class="fs-4 fw-semibold">@FormatPercent(_dashboard.ParticipantCompletionPercent)</div>
                        <div class="small text-muted">participants completed</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Goal progress</div>
                        <div class="fs-4 fw-semibold">@FormatNullablePercent(_dashboard.AverageLatestProgressPercent)</div>
                        <div class="small text-muted">@_dashboard.GoalAssignmentCount assignments</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Assessment completion</div>
                        <div class="fs-4 fw-semibold">@FormatPercent(_dashboard.AssessmentCompletionPercent)</div>
                        <div class="small text-muted">@_dashboard.SubmittedOrClosedAssessmentCount / @_dashboard.AssessmentCount</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Average score</div>
                        <div class="fs-4 fw-semibold">@FormatDecimal(_dashboard.AverageScore)</div>
                        <div class="small text-muted">scored items</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-2">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Assessments</div>
                        <div class="fs-4 fw-semibold">@_dashboard.AssessmentCount</div>
                        <div class="small text-muted">total</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <strong>Distribuzione score</strong>
            </div>
            <div class="card-body">
                @if (_dashboard.ScoreDistribution.Count == 0)
                {
                    <div class="text-muted">Nessuno score disponibile.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Score</th>
                                    <th>Count</th>
                                    <th>Distribuzione</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bucket in _dashboard.ScoreDistribution)
                                {
                                    <tr>
                                        <td><span class="badge text-bg-light">@bucket.Score</span></td>
                                        <td>@bucket.Count</td>
                                        <td>
                                            <div class="progress" style="height: 8px;">
                                                <div class="progress-bar" style="width: @GetScoreBucketPercent(bucket.Count)%"></div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-xxl-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Breakdown per OrgUnit</strong>
                    </div>
                    <div class="card-body">
                        @RenderBreakdownTable(_dashboard.OrgUnitBreakdown, "Nessun dato OrgUnit disponibile.")
                    </div>
                </div>
            </div>

            <div class="col-12 col-xxl-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Breakdown per JobRole</strong>
                    </div>
                    <div class="card-body">
                        @RenderBreakdownTable(_dashboard.JobRoleBreakdown, "Nessun dato JobRole disponibile.")
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "cycleId")]
    public Guid? CycleId { get; set; }

    private bool _loading;
    private string? _error;
    private Guid? _selectedCycleId;
    private PerformanceDashboardDto? _dashboard;

    protected override async Task OnParametersSetAsync()
    {
        _selectedCycleId = CycleId;
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _dashboard = await PerformanceDashboardAppService.GetAsync(new GetPerformanceDashboardInput
            {
                CycleId = _selectedCycleId
            });
            _selectedCycleId = _dashboard.SelectedCycleId;
        }
        catch (Exception ex)
        {
            _error = GetFriendlyErrorMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnCycleChangedAsync(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var cycleId))
        {
            return Task.CompletedTask;
        }

        _selectedCycleId = cycleId;
        NavigationManager.NavigateTo(BuildUrl(cycleId));
        return Task.CompletedTask;
    }

    private string BuildUrl(Guid cycleId)
    {
        var url = QueryHelpers.AddQueryString("/hr/performance-dashboard", "cycleId", cycleId.ToString());
        var tenant = GetCurrentTenantFromUrl();

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        return url;
    }

    private string? GetCurrentTenantFromUrl()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("__tenant", out var tenantValues))
        {
            var tenant = tenantValues.ToString();
            return string.IsNullOrWhiteSpace(tenant) ? null : tenant;
        }

        return null;
    }

    private decimal GetScoreBucketPercent(int count)
    {
        if (_dashboard is null || _dashboard.ScoreDistribution.Count == 0)
        {
            return 0m;
        }

        var max = _dashboard.ScoreDistribution.Max(x => x.Count);
        return max == 0 ? 0m : Math.Round(count * 100m / max, 2);
    }

    private RenderFragment RenderBreakdownTable(List<PerformanceDashboardBreakdownDto> rows, string emptyText) => builder =>
    {
        if (rows.Count == 0)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "text-muted");
            builder.AddContent(2, emptyText);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(3, "div");
        builder.AddAttribute(4, "class", "table-responsive");
        builder.OpenElement(5, "table");
        builder.AddAttribute(6, "class", "table table-sm align-middle");
        builder.AddMarkupContent(7, "<thead><tr><th>Gruppo</th><th class=\"text-end\">Participants</th><th class=\"text-end\">Goals</th><th class=\"text-end\">Avg progress</th><th class=\"text-end\">Assessment %</th><th class=\"text-end\">Avg score</th></tr></thead>");
        builder.OpenElement(8, "tbody");

        var sequence = 9;
        foreach (var row in rows)
        {
            builder.OpenElement(sequence++, "tr");
            builder.OpenElement(sequence++, "td");
            builder.AddContent(sequence++, row.GroupName);
            builder.CloseElement();
            builder.OpenElement(sequence++, "td");
            builder.AddAttribute(sequence++, "class", "text-end");
            builder.AddContent(sequence++, row.ParticipantCount);
            builder.CloseElement();
            builder.OpenElement(sequence++, "td");
            builder.AddAttribute(sequence++, "class", "text-end");
            builder.AddContent(sequence++, row.GoalAssignmentCount);
            builder.CloseElement();
            builder.OpenElement(sequence++, "td");
            builder.AddAttribute(sequence++, "class", "text-end");
            builder.AddContent(sequence++, FormatNullablePercent(row.AverageLatestProgressPercent));
            builder.CloseElement();
            builder.OpenElement(sequence++, "td");
            builder.AddAttribute(sequence++, "class", "text-end");
            builder.AddContent(sequence++, FormatPercent(row.AssessmentCompletionPercent));
            builder.CloseElement();
            builder.OpenElement(sequence++, "td");
            builder.AddAttribute(sequence++, "class", "text-end");
            builder.AddContent(sequence++, FormatDecimal(row.AverageScore));
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string FormatPercent(decimal value)
        => $"{value:0.##}%";

    private static string FormatNullablePercent(decimal? value)
        => value.HasValue ? $"{value.Value:0.##}%" : "-";

    private static string FormatDecimal(decimal? value)
        => value.HasValue ? value.Value.ToString("0.##") : "-";

    private static string GetFriendlyErrorMessage(Exception ex)
    {
        var message = ex.Message;

        if (message.Contains("CurrentUserIsNotHr", StringComparison.OrdinalIgnoreCase))
        {
            return "Utente non autorizzato: serve ruolo HR o admin.";
        }

        if (message.Contains("TenantMissing", StringComparison.OrdinalIgnoreCase))
        {
            return "Tenant mancante nella richiesta.";
        }

        if (message.Contains("HrCycleNotFound", StringComparison.OrdinalIgnoreCase))
        {
            return "Ciclo non trovato.";
        }

        return message;
    }
}
