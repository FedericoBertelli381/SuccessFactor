@page "/my/goals/{AssignmentId:guid}"
@inherits GoalDetailBase

<PageTitle>Goal Detail</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Goal detail</h2>

            @if (GoalItem is not null)
            {
                <div class="text-muted">
                    @GoalItem.GoalName
                    <span class="mx-2">•</span>
                    @GoalsData?.CycleName
                    <span class="mx-2">•</span>
                    fase: <strong>@(GoalsData?.CurrentPhaseCode ?? "-")</strong>
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="BackToMyPage">
                Torna a My
            </button>

            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@Loading">
                @if (Loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Aggiorna
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <StatusAlert Message="@Error" Kind="danger" />
    }

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <StatusAlert Message="@SuccessMessage" Kind="success" />
    }

    @if (Loading && GoalItem is null)
    {
        <LoadingState Text="Caricamento dettaglio goal..." />
    }
    else if (GoalItem is null && !string.IsNullOrWhiteSpace(Error))
    {
        <EmptyState Title="Goal non disponibile" Text="Correggi il problema indicato nel banner e riprova." />
    }
    else if (GoalItem is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Dettaglio goal</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="text-muted small">Titolo</div>
                                <div class="fw-semibold">@GoalItem.GoalName</div>
                            </div>
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Peso</div>
                                <div>@GoalItem.Weight</div>
                            </div>
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Status</div>
                                <div>@GoalItem.Status</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Target</div>
                                <div>@FormatDecimal(GoalItem.TargetValue)</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Scadenza</div>
                                <div>@FormatDate(GoalItem.DueDate)</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Editabile</div>
                                <div>@YesNo(GoalItem.CanEdit)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Summary</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="text-muted small">Entries</div>
                            <div class="fs-4 fw-semibold">@SummaryEntriesCount</div>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">Ultimo progress</div>
                            <div>@FormatDecimal(SummaryLastProgressPercent)</div>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">Ultimo actual value</div>
                            <div>@FormatDecimal(SummaryLastActualValue)</div>
                        </div>

                        <div>
                            <div class="text-muted small">Ultima data</div>
                            <div>@FormatDate(SummaryLastEntryDate)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-5">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <strong>Aggiungi aggiornamento</strong>
                    </div>
                    <div class="card-body">
                        @if (!GoalItem.CanEdit || !CanEditAnyGoalField())
                        {
                            <div class="alert alert-warning mb-0">
                                In questa fase non puoi modificare il progress del goal.
                            </div>
                        }
                        else
                        {
                            <EditForm Model="Input" OnValidSubmit="SaveAsync">
                                <DataAnnotationsValidator />
                                <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                                <div class="mb-3">
                                    <label class="form-label">Data</label>
                                    <InputDate class="form-control" @bind-Value="Input.EntryDate" />
                                </div>

                                @if (IsEditAccess(GoalItem.ProgressPercentAccess))
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Progress percent</label>
                                        <InputNumber class="form-control" @bind-Value="Input.ProgressPercent" />
                                        <div class="form-text">Valore atteso: 0..100</div>
                                    </div>
                                }

                                @if (IsEditAccess(GoalItem.ActualValueAccess))
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Actual value</label>
                                        <InputNumber class="form-control" @bind-Value="Input.ActualValue" />
                                    </div>
                                }

                                @if (IsEditAccess(GoalItem.NoteAccess))
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Note</label>
                                        <InputTextArea class="form-control" @bind-Value="Input.Note" />
                                    </div>
                                }

                                <button class="btn btn-primary" type="submit" disabled="@Saving">
                                    @if (Saving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Salva aggiornamento
                                </button>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Ultimo progress</strong>
                    </div>
                    <div class="card-body">
                        @if (LastProgress is null)
                        {
                            <div class="text-muted">Nessun aggiornamento presente.</div>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Data</div>
                                    <div>@FormatDate(LastProgress.EntryDate)</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Progress percent</div>
                                    <div>@FormatDecimal(LastProgress.ProgressPercent)</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Actual value</div>
                                    <div>@FormatDecimal(LastProgress.ActualValue)</div>
                                </div>
                                <div class="col-12">
                                    <div class="text-muted small">Note</div>
                                    <div>@(string.IsNullOrWhiteSpace(LastProgress.Note) ? "-" : LastProgress.Note)</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>History</strong>
            </div>
            <div class="card-body">
                @if (History.Count == 0)
                {
                    <div class="text-muted">Nessun aggiornamento presente.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Progress %</th>
                                    <th>Actual value</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in History)
                                {
                                    <tr>
                                        <td>@FormatDate(entry.EntryDate)</td>
                                        <td>@FormatDecimal(entry.ProgressPercent)</td>
                                        <td>@FormatDecimal(entry.ActualValue)</td>
                                        <td>@(string.IsNullOrWhiteSpace(entry.Note) ? "-" : entry.Note)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>
