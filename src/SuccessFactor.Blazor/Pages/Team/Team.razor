@page "/team"
@attribute [Authorize(Roles = SuccessFactorRoles.AdminOrManager)]
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.AspNetCore.Components
@using SuccessFactor.Team
@using SuccessFactor.My.Dtos
@inject ITeamDashboardAppService TeamDashboardAppService
@inject ITeamGoalsAppService TeamGoalsAppService
@inject ITeamAssessmentsAppService TeamAssessmentsAppService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime


<PageTitle>Team Performance</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Team Performance</h2>

            @if (_dashboard is not null)
            {
                <div class="text-muted">
                    manager: @_dashboard.ActorEmployeeName
                    @if (!string.IsNullOrWhiteSpace(_dashboard.CycleName))
                    {
                        <span class="mx-2">•</span>
                        @_dashboard.CycleName
                    }
                    @if (!string.IsNullOrWhiteSpace(_dashboard.CurrentPhaseCode))
                    {
                        <span class="mx-2">•</span>
                        <span>fase target: <strong>@_dashboard.CurrentPhaseCode</strong></span>
                                        }
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary"
                    @onclick="RefreshAsync"
                    disabled="@(_loading || _advancing)">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Aggiorna
            </button>

            @if (_dashboard is not null && _dashboard.SelectedEmployeeId.HasValue && _dashboard.CanAdvancePhase)
            {
                <button class="btn btn-primary"
                        @onclick="AdvancePhaseAsync"
                        disabled="@(_loading || _advancing)">
                    @if (_advancing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Advance phase
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">
            @_error
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">
            @_successMessage
        </div>
    }

    @if (_loading && _dashboard is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento team dashboard...</span>
        </div>
    }
    else if (_dashboard is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Team members</strong>
                    </div>
                    <div class="card-body">
                        @if (_dashboard.TeamMembers.Count == 0)
                        {
                            <div class="text-muted">Nessun dipendente gestito.</div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Seleziona dipendente</label>
                                <select class="form-select"
                                        value="@(_selectedEmployeeId?.ToString() ?? string.Empty)"
                                        @onchange="OnSelectedEmployeeChanged">
                                    <option value="">-- seleziona --</option>
                                    @foreach (var member in _dashboard.TeamMembers)
                                    {
                                        <option value="@member.EmployeeId">@member.FullName</option>
                                    }
                                </select>
                            </div>

                            <div class="small text-muted">
                                membri nel perimetro: @_dashboard.TeamMembers.Count
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Contesto target</strong>
                    </div>
                    <div class="card-body">
                        @if (!_dashboard.SelectedEmployeeId.HasValue)
                        {
                            <div class="text-muted">Seleziona un dipendente del team.</div>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Dipendente</div>
                                    <div>@(_dashboard.SelectedEmployeeName ?? "-")</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">RoleCode</div>
                                    <div>@_dashboard.RoleCodeUsed</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Ciclo</div>
                                    <div>@_dashboard.CycleName</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Status ciclo</div>
                                    <div>@_dashboard.CycleStatus</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Fase corrente</div>
                                    <div>@(_dashboard.CurrentPhaseCode ?? "-")</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Puoi avanzare fase</div>
                                    <div>@YesNo(_dashboard.CanAdvancePhase)</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <strong>Goals del target</strong>
            </div>
            <div class="card-body">
                @if (!_dashboard?.SelectedEmployeeId.HasValue ?? true)
                {
                    <div class="text-muted">Seleziona un dipendente del team.</div>
                }
                else if (_goals is null)
                {
                    <div class="text-muted">Nessun dato goal.</div>
                }
                else if (_goals.Items.Count == 0)
                {
                    <div class="text-muted">Nessun goal assegnato al target.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Goal</th>
                                    <th class="text-end">Peso</th>
                                    <th>Status</th>
                                    <th>Ultimo progress</th>
                                    <th>Scadenza</th>
                                    <th>Permessi</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _goals.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.GoalName</div>
                                            <div class="small text-muted">
                                                target: @FormatDecimal(item.TargetValue)
                                            </div>
                                        </td>
                                        <td class="text-end">@item.Weight</td>
                                        <td>
                                            <span class="badge text-bg-light">@item.Status</span>
                                        </td>
                                        <td>
                                            @if (item.LastProgress is null)
                                            {
                                                <span class="text-muted">mai aggiornato</span>
                                            }
                                            else
                                            {
                                                <div>@FormatDate(item.LastProgress.EntryDate)</div>
                                                <div class="small text-muted">
                                                    %@FormatDecimal(item.LastProgress.ProgressPercent)
                                                </div>
                                            }
                                        </td>
                                        <td>@FormatDate(item.DueDate)</td>
                                        <td>
                                            <div class="small">
                                                Edit: <strong>@YesNo(item.CanEdit)</strong>
                                            </div>
                                            <div class="small text-muted">
                                                P:@item.ProgressPercentAccess
                                                • A:@item.ActualValueAccess
                                                • N:@item.NoteAccess
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-outline-primary btn-sm"
                                                    @onclick="() => OpenGoalDetail(item.AssignmentId)">
                                                Apri
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <strong>Assessments del target</strong>
            </div>
            <div class="card-body">
                @if (!_dashboard?.SelectedEmployeeId.HasValue ?? true)
                {
                    <div class="text-muted">Seleziona un dipendente del team.</div>
                }
                else if (_assessments is null)
                {
                    <div class="text-muted">Nessun dato assessment.</div>
                }
                else if (_assessments.Items.Count == 0)
                {
                    <div class="text-muted">Nessun assessment assegnato al target.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Status</th>
                                    <th>Model</th>
                                    <th>Items</th>
                                    <th>Required mancanti</th>
                                    <th>Permessi</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _assessments.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.AssessmentType</div>
                                            <div class="small text-muted">@item.TargetEmployeeName</div>
                                        </td>
                                        <td>
                                            <span class="badge text-bg-light">@item.Status</span>
                                        </td>
                                        <td>
                                            <div>@(item.ModelName ?? "-")</div>
                                            <div class="small text-muted">
                                                score: @item.MinScore - @item.MaxScore
                                            </div>
                                        </td>
                                        <td>
                                            @item.ItemsCount
                                            <div class="small text-muted">
                                                required: @item.RequiredItemsCount
                                            </div>
                                        </td>
                                        <td>
                                            @if (item.MissingRequiredCount > 0)
                                            {
                                                <span class="badge text-bg-warning">
                                                    @item.MissingRequiredCount mancanti
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-success">
                                                    completi
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <div class="small">
                                                Edit: <strong>@YesNo(item.CanEdit)</strong>
                                            </div>
                                            <div class="small">
                                                Submit: <strong>@YesNo(item.CanSubmit)</strong>
                                            </div>
                                            <div class="small text-muted">
                                                S:@item.ScoreAccess
                                                • C:@item.CommentAccess
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-outline-primary btn-sm"
                                                    @onclick="() => OpenAssessmentDetail(item.AssessmentId)">
                                                Apri
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "targetEmployeeId")]
    public Guid? TargetEmployeeId { get; set; }
    private bool _loading;
    private bool _advancing;
    private string? _error;
    private string? _successMessage;

    private TeamDashboardDto? _dashboard;
    private MyGoalsDto? _goals;
    private MyAssessmentsDto? _assessments;
    private Guid? _selectedEmployeeId;

    private void NavigateToTeamPage()
    {
        var url = "/team";
        var tenant = GetCurrentTenantFromUrl();

        if (_selectedEmployeeId.HasValue)
        {
            url = QueryHelpers.AddQueryString(url, "targetEmployeeId", _selectedEmployeeId.Value.ToString());
        }

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        NavigationManager.NavigateTo(url);
    }
    private async Task RefreshAsync()
    {
        _successMessage = null;
        await Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _dashboard = await TeamDashboardAppService.GetAsync(new GetTeamDashboardInput
            {
                TargetEmployeeId = _selectedEmployeeId
            });

            _selectedEmployeeId = _dashboard.SelectedEmployeeId;

            if (_dashboard.SelectedEmployeeId.HasValue)
            {
                var goalsTask = TeamGoalsAppService.GetAsync(new GetTeamGoalsInput
                {
                    TargetEmployeeId = _dashboard.SelectedEmployeeId.Value,
                    CycleId = _dashboard.CycleId
                });

                var assessmentsTask = TeamAssessmentsAppService.GetAsync(new GetTeamAssessmentsInput
                {
                    TargetEmployeeId = _dashboard.SelectedEmployeeId.Value,
                    CycleId = _dashboard.CycleId
                });

                await Task.WhenAll(goalsTask, assessmentsTask);

                _goals = await goalsTask;
                _assessments = await assessmentsTask;
            }
            else
            {
                _goals = null;
                _assessments = null;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
    protected override async Task OnParametersSetAsync()
    {
        if (TargetEmployeeId.HasValue)
        {
            _selectedEmployeeId = TargetEmployeeId.Value;
        }

        await LoadAsync();
    }
    private async Task OnSelectedEmployeeChanged(ChangeEventArgs e)
{
    _successMessage = null;
    _error = null;

    var rawValue = e.Value?.ToString();

    if (string.IsNullOrWhiteSpace(rawValue))
    {
        _selectedEmployeeId = null;
        await LoadAsync();
        return;
    }

    if (Guid.TryParse(rawValue, out var employeeId))
    {
        _selectedEmployeeId = employeeId;
        await LoadAsync();
    }
}

    private async Task AdvancePhaseAsync()
    {
        if (_dashboard is null || !_dashboard.SelectedEmployeeId.HasValue || _advancing || !_dashboard.CanAdvancePhase)
        {
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Confermi l'avanzamento della fase per {_dashboard.SelectedEmployeeName}?");

        if (!confirmed)
        {
            return;
        }

        _advancing = true;
        _error = null;
        _successMessage = null;

        try
        {
            await TeamDashboardAppService.AdvancePhaseAsync(
     _dashboard.SelectedEmployeeId.Value,
     _dashboard.CycleId);

            NavigateToTeamPage();

            _successMessage = "Fase avanzata correttamente.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _advancing = false;
        }
    }

    private string? GetCurrentTenantFromUrl()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("__tenant", out var tenantValues))
        {
            var tenant = tenantValues.ToString();
            return string.IsNullOrWhiteSpace(tenant) ? null : tenant;
        }

        return null;
    }
    private void OpenAssessmentDetail(Guid assessmentId)
    {
        if (!_selectedEmployeeId.HasValue)
        {
            return;
        }

        var url = $"/team/assessments/{_selectedEmployeeId.Value}/{assessmentId}";
        var tenant = GetCurrentTenantFromUrl();

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        NavigationManager.NavigateTo(url);
    }
    private void OpenGoalDetail(Guid assignmentId)
    {
        if (!_selectedEmployeeId.HasValue)
        {
            return;
        }

        var url = $"/team/goals/{_selectedEmployeeId.Value}/{assignmentId}";
        var tenant = GetCurrentTenantFromUrl();

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        NavigationManager.NavigateTo(url);
    }
    private static string FormatDate(DateOnly? value)
    => value?.ToString("dd/MM/yyyy") ?? "-";

    private static string FormatDecimal(decimal? value)
        => value?.ToString("0.##") ?? "-";
    private static string YesNo(bool value) => value ? "Sě" : "No";
}