@page "/team/assessments/{TargetEmployeeId:guid}/{AssessmentId:guid}"
@using Microsoft.AspNetCore.WebUtilities
@using SuccessFactor.My.Dtos
@using SuccessFactor.Team
@using Microsoft.JSInterop
@inject ITeamAssessmentsAppService TeamAssessmentsAppService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Team Assessment Detail</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Team Assessment Detail</h2>

            @if (_assessment is not null)
            {
                <div class="text-muted">
                    @_assessment.AssessmentType
                    <span class="mx-2">•</span>
                    @_assessment.TargetEmployeeName
                    <span class="mx-2">•</span>
                    fase: <strong>@(_assessment.CurrentPhaseCode ?? "-")</strong>
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="BackToTeamPage">
                Torna a Team
            </button>

            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@(_loading || _submitting)">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Aggiorna
            </button>

            @if (_assessment is not null && _assessment.CanSubmit)
            {
                <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@(_loading || _submitting)">
                    @if (_submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Submit
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">
            @_error
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">
            @_successMessage
        </div>
    }
    @if (_loading && _assessment is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento assessment del target...</span>
        </div>
    }
    else if (_assessment is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Contesto assessment</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Tipo</div>
                                <div class="fw-semibold">@_assessment.AssessmentType</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Status</div>
                                <div>@_assessment.Status</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Model</div>
                                <div>@(_assessment.ModelName ?? "-")</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="text-muted small">Target</div>
                                <div>@_assessment.TargetEmployeeName</div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="text-muted small">Evaluator</div>
                                <div>@_assessment.EvaluatorEmployeeName</div>
                            </div>

                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Score range</div>
                                <div>@_assessment.MinScore - @_assessment.MaxScore</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Items</div>
                                <div>@_assessment.ItemsCount</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Required mancanti</div>
                                <div>@_assessment.MissingRequiredCount</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Permessi sul target</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            Edit: <strong>@YesNo(_assessment.CanEdit)</strong>
                        </div>
                        <div class="mb-2">
                            Submit: <strong>@YesNo(_assessment.CanSubmit)</strong>
                        </div>
                        <div class="small text-muted">
                            Score: @_assessment.ScoreAccess
                            <br />
                            Comment: @_assessment.CommentAccess
                            <br />
                            Evidence: @_assessment.EvidenceAttachmentAccess
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>Competenze</strong>
            </div>
            <div class="card-body">
                @if (_assessment.Items.Count == 0)
                {
                    <div class="text-muted">Nessun item da visualizzare.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Competenza</th>
                                    <th class="text-center">Required</th>
                                    <th class="text-end">Peso</th>
                                    <th class="text-center">Score</th>
                                    <th>Comment</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _assessment.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.CompetencyName</div>
                                            <div class="small text-muted">@item.CompetencyCode</div>
                                        </td>
                                        <td class="text-center">
                                            @if (item.IsRequired)
                                            {
                                                <span class="badge text-bg-warning">Required</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No</span>
                                            }
                                        </td>
                                        <td class="text-end">@FormatDecimal(item.Weight)</td>
                                        <td>
                                            @if (_assessment.CanEdit && string.Equals(_assessment.ScoreAccess, "Edit", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input type="number"
                                                       class="form-control form-control-sm"
                                                       @bind="_editScores[item.CompetencyId]" />
                                            }
                                            else
                                            {
                                                @FormatInt(item.Score)
                                            }
                                        </td>

                                        <td>
                                            @if (_assessment.CanEdit && string.Equals(_assessment.CommentAccess, "Edit", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input type="text"
                                                       class="form-control form-control-sm"
                                                       @bind="_editComments[item.CompetencyId]" />
                                            }
                                            else
                                            {
                                                @(string.IsNullOrWhiteSpace(item.Comment) ? "-" : item.Comment)
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (_assessment.CanEdit)
                                            {
                                                <button class="btn btn-sm btn-primary"
                                                        @onclick="() => SaveItemAsync(item.CompetencyId)"
                                                        disabled="@_savingItems.Contains(item.CompetencyId)">
                                                    @if (_savingItems.Contains(item.CompetencyId))
                                                    {
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <span>Salva</span>
                                                    }
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid TargetEmployeeId { get; set; }

    [Parameter]
    public Guid AssessmentId { get; set; }

    private bool _loading;
    private bool _submitting;
    private string? _error;
    private string? _successMessage;
    private MyAssessmentItemDto? _assessment;
    private Dictionary<Guid, int?> _editScores = new();
    private Dictionary<Guid, string?> _editComments = new();
    private HashSet<Guid> _savingItems = new();
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        _successMessage = null;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var assessments = await TeamAssessmentsAppService.GetAsync(new GetTeamAssessmentsInput
            {
                TargetEmployeeId = TargetEmployeeId
            });

            _assessment = assessments.Items.FirstOrDefault(x => x.AssessmentId == AssessmentId);

            if (_assessment is null)
            {
                _error = "Assessment non trovato tra quelli del target selezionato.";
            }
            else
            {
                _editScores = _assessment.Items.ToDictionary(
                    x => x.CompetencyId,
                    x => x.Score);

                _editComments = _assessment.Items.ToDictionary(
                    x => x.CompetencyId,
                    x => x.Comment);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
    private async Task SubmitAsync()
    {
        if (_assessment is null || !_assessment.CanSubmit || _submitting)
        {
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Confermi l'invio dell'assessment di {_assessment.TargetEmployeeName}?");

        if (!confirmed)
        {
            return;
        }

        _submitting = true;
        _error = null;
        _successMessage = null;

        try
        {
            await TeamAssessmentsAppService.SubmitAsync(
                TargetEmployeeId,
                AssessmentId,
                _assessment.CycleId);

            await LoadAsync();

            _successMessage = "Assessment inviato correttamente.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
    private void BackToTeamPage()
    {
        var url = "/team";
        var tenant = GetCurrentTenantFromUrl();

        url = QueryHelpers.AddQueryString(url, "targetEmployeeId", TargetEmployeeId.ToString());

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        NavigationManager.NavigateTo(url);
    }

    private string? GetCurrentTenantFromUrl()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("__tenant", out var tenantValues))
        {
            var tenant = tenantValues.ToString();
            return string.IsNullOrWhiteSpace(tenant) ? null : tenant;
        }

        return null;
    }
    private async Task SaveItemAsync(Guid competencyId)
    {
        if (_assessment == null || !_assessment.CanEdit)
        {
            return;
        }

        if (_savingItems.Contains(competencyId))
        {
            return;
        }

        _savingItems.Add(competencyId);
        _error = null;
        _successMessage = null;

        try
        {
            await TeamAssessmentsAppService.UpdateItemAsync(
                TargetEmployeeId,
                AssessmentId,
                new UpdateTeamAssessmentItemDto
                {
                    CompetencyId = competencyId,
                    Score = _editScores[competencyId],
                    Comment = _editComments[competencyId]
                },
                _assessment.CycleId);

            _successMessage = "Riga salvata correttamente.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingItems.Remove(competencyId);
        }
    }
    private static string YesNo(bool value) => value ? "Sì" : "No";

    private static string FormatDecimal(decimal? value)
        => value?.ToString("0.##") ?? "-";

    private static string FormatInt(int? value)
        => value?.ToString() ?? "-";
}