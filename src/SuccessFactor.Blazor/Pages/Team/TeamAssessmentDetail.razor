@page "/team/assessments/{TargetEmployeeId:guid}/{AssessmentId:guid}"
@using Microsoft.AspNetCore.WebUtilities
@using SuccessFactor.My.Dtos
@using SuccessFactor.Team
@using Microsoft.JSInterop
@inject ITeamAssessmentsAppService TeamAssessmentsAppService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Team Assessment Detail</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Team Assessment Detail</h2>

            @if (_assessment is not null)
            {
                <div class="text-muted">
                    @_assessment.AssessmentType
                    <span class="mx-2">•</span>
                    @_assessment.TargetEmployeeName
                    <span class="mx-2">•</span>
                    fase: <strong>@(_assessment.CurrentPhaseCode ?? "-")</strong>
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="BackToTeamPageAsync">
                Torna a Team
            </button>

            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@(_loading || _submitting || _bulkSaving)">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Aggiorna
            </button>

            @if (_assessment is not null && CanSaveAll())
            {
                <button class="btn btn-success" @onclick="SaveAllAsync" disabled="@(_loading || _submitting || _bulkSaving || !HasDirtyItems())">
                    @if (_bulkSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Save all
                </button>
            }

            @if (_assessment is not null && _assessment.CanSubmit)
            {
                <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@(_loading || _submitting || _bulkSaving || HasDirtyItems())">
                    @if (_submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Submit
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">
            @_error
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">
            @_successMessage
        </div>
    }
    @if (HasDirtyItems() && CanSaveAll())
    {
        <div class="alert alert-warning d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
            <span>Hai modifiche non salvate. Usa <strong>Save all</strong> prima di aggiornare, tornare indietro o fare submit.</span>
            <span class="badge text-bg-warning">Dirty: @GetDirtyCount()</span>
        </div>
    }
    @if (_loading && _assessment is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento assessment del target...</span>
        </div>
    }
    else if (_assessment is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Contesto assessment</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Tipo</div>
                                <div class="fw-semibold">@_assessment.AssessmentType</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Status</div>
                                <div>@_assessment.Status</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Model</div>
                                <div>@(_assessment.ModelName ?? "-")</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="text-muted small">Target</div>
                                <div>@_assessment.TargetEmployeeName</div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="text-muted small">Evaluator</div>
                                <div>@_assessment.EvaluatorEmployeeName</div>
                            </div>

                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Score range</div>
                                <div>@_assessment.MinScore - @_assessment.MaxScore</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Items</div>
                                <div>@_assessment.ItemsCount</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Required mancanti</div>
                                <div>@_assessment.MissingRequiredCount</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Permessi sul target</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            Edit: <strong>@YesNo(_assessment.CanEdit)</strong>
                        </div>
                        <div class="mb-2">
                            Submit: <strong>@YesNo(_assessment.CanSubmit)</strong>
                        </div>
                        <div class="small text-muted">
                            Score: @_assessment.ScoreAccess
                            <br />
                            Comment: @_assessment.CommentAccess
                            <br />
                            Evidence: @_assessment.EvidenceAttachmentAccess
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <strong>Competenze</strong>

                    @if (HasDirtyItems())
                    {
                        <span class="badge text-bg-warning">
                            Modifiche non salvate: @GetDirtyCount()
                        </span>
                    }
                </div>
            </div>
            <div class="card-body">
                @if (_assessment.Items.Count == 0)
                {
                    <div class="text-muted">Nessun item da visualizzare.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Competenza</th>
                                    <th class="text-center">Required</th>
                                    <th class="text-end">Peso</th>
                                    <th class="text-center">Score</th>
                                    <th>Comment</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _assessment.Items)
                                {
                                    <tr class="@(IsDirty(item.CompetencyId) ? "table-warning" : null)">
                                        <td>
                                            <div class="fw-semibold">@item.CompetencyName</div>
                                            <div class="small text-muted">@item.CompetencyCode</div>
                                        </td>
                                        <td class="text-center">
                                            @if (item.IsRequired)
                                            {
                                                <span class="badge text-bg-warning">Required</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No</span>
                                            }
                                        </td>
                                        <td class="text-end">@FormatDecimal(item.Weight)</td>
                                        <td>
                                            @if (_assessment.CanEdit && string.Equals(_assessment.ScoreAccess, "Edit", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input type="number"
                                                       class="form-control form-control-sm"
                                                       min="@_assessment.MinScore"
                                                       max="@_assessment.MaxScore"
                                                       disabled="@IsInputDisabled(item.CompetencyId)"
                                                       @bind="_editScores[item.CompetencyId]" />
                                            }
                                            else
                                            {
                                                @FormatInt(item.Score)
                                            }
                                        </td>

                                        <td>
                                            @if (_assessment.CanEdit && string.Equals(_assessment.CommentAccess, "Edit", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input type="text"
                                                       class="form-control form-control-sm"
                                                       disabled="@IsInputDisabled(item.CompetencyId)"
                                                       @bind="_editComments[item.CompetencyId]" />
                                            }
                                            else
                                            {
                                                @(string.IsNullOrWhiteSpace(item.Comment) ? "-" : item.Comment)
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (_assessment.CanEdit)
                                            {
                                                <div class="d-flex justify-content-end align-items-center gap-2">
                                                @if (IsDirty(item.CompetencyId))
                                                {
                                                    <span class="badge text-bg-warning">Dirty</span>
                                                }
                                                <button class="btn btn-sm btn-primary"
                                                        @onclick="() => SaveItemAsync(item.CompetencyId)"
                                                        disabled="@(_savingItems.Contains(item.CompetencyId) || !IsDirty(item.CompetencyId) || _bulkSaving)">
                                                    @if (_savingItems.Contains(item.CompetencyId))
                                                    {
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <span>Salva</span>
                                                    }
                                                </button>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid TargetEmployeeId { get; set; }

    [Parameter]
    public Guid AssessmentId { get; set; }

    private bool _loading;
    private bool _submitting;
    private bool _bulkSaving;
    private string? _error;
    private string? _successMessage;
    private MyAssessmentItemDto? _assessment;
    private Dictionary<Guid, int?> _editScores = new();
    private Dictionary<Guid, string?> _editComments = new();
    private Dictionary<Guid, int?> _originalScores = new();
    private Dictionary<Guid, string?> _originalComments = new();
    private HashSet<Guid> _savingItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        if (!await ConfirmDiscardChangesAsync())
        {
            return;
        }

        _successMessage = null;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var assessments = await TeamAssessmentsAppService.GetAsync(new GetTeamAssessmentsInput
            {
                TargetEmployeeId = TargetEmployeeId
            });

            _assessment = assessments.Items.FirstOrDefault(x => x.AssessmentId == AssessmentId);

            if (_assessment is null)
            {
                _error = "Assessment non trovato tra quelli del target selezionato.";
            }
            else
            {
                _editScores = _assessment.Items.ToDictionary(
                    x => x.CompetencyId,
                    x => x.Score);

                _editComments = _assessment.Items.ToDictionary(
                    x => x.CompetencyId,
                    x => x.Comment);

                _originalScores = _assessment.Items.ToDictionary(
                    x => x.CompetencyId,
                    x => x.Score);

                _originalComments = _assessment.Items.ToDictionary(
                    x => x.CompetencyId,
                    x => x.Comment);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
    private async Task SubmitAsync()
    {
        if (_assessment is null || !_assessment.CanSubmit || _submitting || _bulkSaving)
        {
            return;
        }

        if (HasDirtyItems())
        {
            _error = "Salva prima le modifiche pendenti.";
            _successMessage = null;
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Confermi l'invio dell'assessment di {_assessment.TargetEmployeeName}?");

        if (!confirmed)
        {
            return;
        }

        _submitting = true;
        _error = null;
        _successMessage = null;

        try
        {
            await TeamAssessmentsAppService.SubmitAsync(
                TargetEmployeeId,
                AssessmentId,
                _assessment.CycleId);

            await LoadAsync();

            _successMessage = "Assessment inviato correttamente.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
    private async Task BackToTeamPageAsync()
    {
        if (!await ConfirmDiscardChangesAsync())
        {
            return;
        }

        var url = "/team";
        var tenant = GetCurrentTenantFromUrl();

        url = QueryHelpers.AddQueryString(url, "targetEmployeeId", TargetEmployeeId.ToString());

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        NavigationManager.NavigateTo(url);
    }

    private string? GetCurrentTenantFromUrl()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("__tenant", out var tenantValues))
        {
            var tenant = tenantValues.ToString();
            return string.IsNullOrWhiteSpace(tenant) ? null : tenant;
        }

        return null;
    }
    private async Task SaveItemAsync(Guid competencyId)
    {
        if (_assessment == null || !_assessment.CanEdit)
        {
            return;
        }

        if (_savingItems.Contains(competencyId))
        {
            return;
        }

        if (!IsDirty(competencyId))
        {
            return;
        }

        if (!ValidateItems(new[] { competencyId }))
        {
            return;
        }

        _savingItems.Add(competencyId);
        _error = null;
        _successMessage = null;

        try
        {
            await TeamAssessmentsAppService.UpdateItemAsync(
                TargetEmployeeId,
                AssessmentId,
                new UpdateTeamAssessmentItemDto
                {
                    CompetencyId = competencyId,
                    Score = _editScores[competencyId],
                    Comment = _editComments[competencyId]
                },
                _assessment.CycleId);

            _successMessage = "Riga salvata correttamente.";
            AcceptChanges(competencyId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingItems.Remove(competencyId);
        }
    }

    private async Task SaveAllAsync()
    {
        if (_assessment is null || !_assessment.CanEdit || _bulkSaving)
        {
            return;
        }

        var dirtyIds = GetDirtyCompetencyIds();

        if (dirtyIds.Count == 0)
        {
            return;
        }

        if (!ValidateItems(dirtyIds))
        {
            return;
        }

        _bulkSaving = true;
        _error = null;
        _successMessage = null;

        try
        {
            var savedCount = await TeamAssessmentsAppService.UpdateItemsAsync(
                TargetEmployeeId,
                AssessmentId,
                new BulkUpdateTeamAssessmentItemsDto
                {
                    Items = dirtyIds
                        .Select(competencyId => new UpdateTeamAssessmentItemDto
                        {
                            CompetencyId = competencyId,
                            Score = _editScores[competencyId],
                            Comment = _editComments[competencyId]
                        })
                        .ToList()
                },
                _assessment.CycleId);

            AcceptChanges(dirtyIds);
            await LoadAsync();
            _successMessage = $"Salvate {savedCount} righe correttamente.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _bulkSaving = false;
        }
    }

    private bool CanSaveAll()
        => _assessment is not null
           && _assessment.CanEdit
           && (string.Equals(_assessment.ScoreAccess, "Edit", StringComparison.OrdinalIgnoreCase)
               || string.Equals(_assessment.CommentAccess, "Edit", StringComparison.OrdinalIgnoreCase));

    private bool IsInputDisabled(Guid competencyId)
        => _bulkSaving || _submitting || _savingItems.Contains(competencyId);

    private bool HasDirtyItems()
        => GetDirtyCompetencyIds().Count > 0;

    private int GetDirtyCount()
        => GetDirtyCompetencyIds().Count;

    private List<Guid> GetDirtyCompetencyIds()
        => _assessment?.Items
            .Select(x => x.CompetencyId)
            .Where(IsDirty)
            .ToList()
            ?? [];

    private bool IsDirty(Guid competencyId)
    {
        var currentScore = _editScores.GetValueOrDefault(competencyId);
        var originalScore = _originalScores.GetValueOrDefault(competencyId);

        if (currentScore != originalScore)
        {
            return true;
        }

        var currentComment = NormalizeText(_editComments.GetValueOrDefault(competencyId));
        var originalComment = NormalizeText(_originalComments.GetValueOrDefault(competencyId));

        return !string.Equals(currentComment, originalComment, StringComparison.Ordinal);
    }

    private bool ValidateItems(IEnumerable<Guid> competencyIds)
    {
        if (_assessment is null)
        {
            return false;
        }

        foreach (var competencyId in competencyIds)
        {
            var item = _assessment.Items.First(x => x.CompetencyId == competencyId);
            var score = _editScores.GetValueOrDefault(competencyId);
            var comment = _editComments.GetValueOrDefault(competencyId);

            if (item.IsRequired
                && string.Equals(_assessment.ScoreAccess, "Edit", StringComparison.OrdinalIgnoreCase)
                && !score.HasValue)
            {
                _error = $"La competenza '{item.CompetencyCode}' richiede uno score.";
                _successMessage = null;
                return false;
            }

            if (score.HasValue
                && (score.Value < _assessment.MinScore || score.Value > _assessment.MaxScore))
            {
                _error = $"Lo score per '{item.CompetencyCode}' deve essere tra {_assessment.MinScore} e {_assessment.MaxScore}.";
                _successMessage = null;
                return false;
            }

            if (!string.IsNullOrEmpty(comment) && comment.Length > 2000)
            {
                _error = $"Il commento per '{item.CompetencyCode}' supera 2000 caratteri.";
                _successMessage = null;
                return false;
            }
        }

        return true;
    }

    private void AcceptChanges(Guid competencyId)
    {
        _originalScores[competencyId] = _editScores.GetValueOrDefault(competencyId);
        _originalComments[competencyId] = _editComments.GetValueOrDefault(competencyId);
    }

    private void AcceptChanges(IEnumerable<Guid> competencyIds)
    {
        foreach (var competencyId in competencyIds)
        {
            AcceptChanges(competencyId);
        }
    }

    private async Task<bool> ConfirmDiscardChangesAsync()
    {
        if (!HasDirtyItems())
        {
            return true;
        }

        return await JSRuntime.InvokeAsync<bool>(
            "confirm",
            "Ci sono modifiche non salvate. Vuoi continuare e perderle?");
    }

    private static string? NormalizeText(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string YesNo(bool value) => value ? "Sì" : "No";

    private static string FormatDecimal(decimal? value)
        => value?.ToString("0.##") ?? "-";

    private static string FormatInt(int? value)
        => value?.ToString() ?? "-";
}
