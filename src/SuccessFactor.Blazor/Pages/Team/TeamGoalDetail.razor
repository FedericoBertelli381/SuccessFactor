@page "/team/goals/{TargetEmployeeId:guid}/{AssignmentId:guid}"
@attribute [Authorize(Roles = SuccessFactorRoles.AdminOrManager)]
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using SuccessFactor.Goals
@using SuccessFactor.My.Dtos
@using SuccessFactor.Team
@using System.ComponentModel.DataAnnotations
@inject ITeamGoalsAppService TeamGoalsAppService
@inject IGoalProgressAppService GoalProgressAppService
@inject NavigationManager NavigationManager

<PageTitle>Team Goal Detail</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1">Team Goal Detail</h2>

            @if (_goal is not null)
            {
                <div class="text-muted">
                    @_goal.GoalName
                    <span class="mx-2">•</span>
                    @_employeeName
                    <span class="mx-2">•</span>
                    fase: <strong>@(_currentPhaseCode ?? "-")</strong>
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="BackToTeamPage">
                Torna a Team
            </button>

            <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Aggiorna
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mb-4">
            @_error
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mb-4">
            @_successMessage
        </div>
    }

    @if (_loading && _goal is null)
    {
        <div class="d-flex align-items-center gap-2 py-4">
            <div class="spinner-border" role="status"></div>
            <span>Caricamento goal del target...</span>
        </div>
    }
    else if (_goal is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Contesto goal</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="text-muted small">Goal</div>
                                <div class="fw-semibold">@_goal.GoalName</div>
                            </div>
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Peso</div>
                                <div>@_goal.Weight</div>
                            </div>
                            <div class="col-12 col-md-3">
                                <div class="text-muted small">Status</div>
                                <div>@_goal.Status</div>
                            </div>

                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Target value</div>
                                <div>@FormatDecimal(_goal.TargetValue)</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Due date</div>
                                <div>@FormatDate(_goal.DueDate)</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="text-muted small">Puoi editare</div>
                                <div>@YesNo(_goal.CanEdit)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Summary</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="text-muted small">Entries</div>
                            <div class="fs-4 fw-semibold">@SummaryEntriesCount</div>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">Ultimo progress</div>
                            <div>@FormatDecimal(SummaryLastProgressPercent)</div>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">Ultimo actual value</div>
                            <div>@FormatDecimal(SummaryLastActualValue)</div>
                        </div>

                        <div>
                            <div class="text-muted small">Ultima data</div>
                            <div>@FormatDate(SummaryLastEntryDate)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-xl-5">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <strong>Aggiungi aggiornamento</strong>
                    </div>
                    <div class="card-body">
                        @if (!_goal.CanEdit || !CanEditAnyGoalField())
                        {
                            <div class="alert alert-warning mb-0">
                                In questa fase non puoi modificare il progress del goal del target.
                            </div>
                        }
                        else
                        {
                            <EditForm Model="_input" OnValidSubmit="SaveAsync">
                                <DataAnnotationsValidator />
                                <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                                <div class="mb-3">
                                    <label class="form-label">Data</label>
                                    <InputDate class="form-control" @bind-Value="_input.EntryDate" />
                                </div>

                                @if (IsEditAccess(_goal.ProgressPercentAccess))
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Progress percent</label>
                                        <InputNumber class="form-control" @bind-Value="_input.ProgressPercent" />
                                        <div class="form-text">Valore atteso: 0..100</div>
                                    </div>
                                }

                                @if (IsEditAccess(_goal.ActualValueAccess))
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Actual value</label>
                                        <InputNumber class="form-control" @bind-Value="_input.ActualValue" />
                                    </div>
                                }

                                @if (IsEditAccess(_goal.NoteAccess))
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Note</label>
                                        <InputTextArea class="form-control" @bind-Value="_input.Note" />
                                    </div>
                                }

                                <button class="btn btn-primary" type="submit" disabled="@_saving">
                                    @if (_saving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Salva aggiornamento
                                </button>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <strong>Ultimo progress</strong>
                    </div>
                    <div class="card-body">
                        @if (_lastProgress is null)
                        {
                            <div class="text-muted">Nessun aggiornamento presente.</div>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Data</div>
                                    <div>@FormatDate(_lastProgress.EntryDate)</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Progress percent</div>
                                    <div>@FormatDecimal(_lastProgress.ProgressPercent)</div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="text-muted small">Actual value</div>
                                    <div>@FormatDecimal(_lastProgress.ActualValue)</div>
                                </div>
                                <div class="col-12">
                                    <div class="text-muted small">Note</div>
                                    <div>@(string.IsNullOrWhiteSpace(_lastProgress.Note) ? "-" : _lastProgress.Note)</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>History</strong>
            </div>
            <div class="card-body">
                @if (_history.Count == 0)
                {
                    <div class="text-muted">Nessun aggiornamento presente.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Progress %</th>
                                    <th>Actual value</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in _history)
                                {
                                    <tr>
                                        <td>@FormatDate(entry.EntryDate)</td>
                                        <td>@FormatDecimal(entry.ProgressPercent)</td>
                                        <td>@FormatDecimal(entry.ActualValue)</td>
                                        <td>@(string.IsNullOrWhiteSpace(entry.Note) ? "-" : entry.Note)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid TargetEmployeeId { get; set; }

    [Parameter]
    public Guid AssignmentId { get; set; }

    private bool _loading;
    private bool _saving;
    private string? _error;
    private string? _successMessage;

    private MyGoalItemDto? _goal;
    private string? _employeeName;
    private string? _currentPhaseCode;

    private List<GoalProgressEntryDto> _history { get; set; } = [];
    private GoalProgressEntryDto? _lastProgress { get; set; }
    private GoalProgressSummaryDto? _summary { get; set; }

    private AddProgressFormModel _input { get; set; } = new();

    private int SummaryEntriesCount => _summary?.EntriesCount ?? _goal?.Summary?.EntriesCount ?? 0;
    private DateOnly? SummaryLastEntryDate => _summary?.LastEntryDate ?? _goal?.Summary?.LastEntryDate;
    private decimal? SummaryLastProgressPercent => _summary?.LastProgressPercent ?? _goal?.Summary?.LastProgressPercent;
    private decimal? SummaryLastActualValue => _summary?.LastActualValue ?? _goal?.Summary?.LastActualValue;

    protected override async Task OnInitializedAsync()
    {
        _input = new AddProgressFormModel
        {
            EntryDate = DateOnly.FromDateTime(DateTime.Today)
        };

        await LoadAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _successMessage = null;

        try
        {
            var goals = await TeamGoalsAppService.GetAsync(new GetTeamGoalsInput
            {
                TargetEmployeeId = TargetEmployeeId
            });

            _employeeName = goals.EmployeeName;
            _currentPhaseCode = goals.CurrentPhaseCode;
            _goal = goals.Items.FirstOrDefault(x => x.AssignmentId == AssignmentId);

            if (_goal is null)
            {
                _error = "Goal non trovato tra quelli del target selezionato.";
                return;
            }

            var historyTask = GoalProgressAppService.GetByAssignmentAsync(AssignmentId);
            var lastTask = GoalProgressAppService.GetLastProgressAsync(AssignmentId);
            var summaryTask = GoalProgressAppService.GetProgressSummaryAsync(AssignmentId);

            await Task.WhenAll(historyTask, lastTask, summaryTask);

            _history = (await historyTask)
                .OrderByDescending(x => x.EntryDate)
                .ToList();

            _lastProgress = await lastTask;
            _summary = await summaryTask;
        }
        catch (Exception ex)
        {
            _error = UiErrorMessage.From(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_goal is null)
        {
            return;
        }

        _saving = true;
        _error = null;
        _successMessage = null;

        try
        {
            var input = new AddGoalProgressDto
            {
                AssignmentId = _goal.AssignmentId,
                EntryDate = _input.EntryDate,
                ProgressPercent = _input.ProgressPercent,
                ActualValue = _input.ActualValue,
                Note = _input.Note
            };

            await GoalProgressAppService.AddAsync(input);

            _input = new AddProgressFormModel
            {
                EntryDate = DateOnly.FromDateTime(DateTime.Today)
            };

            await LoadAsync();

            _successMessage = "Aggiornamento salvato correttamente.";
        }
        catch (Exception ex)
        {
            _error = UiErrorMessage.From(ex);
        }
        finally
        {
            _saving = false;
        }
    }

    private void BackToTeamPage()
    {
        var url = "/team";
        var tenant = GetCurrentTenantFromUrl();

        url = QueryHelpers.AddQueryString(url, "targetEmployeeId", TargetEmployeeId.ToString());

        if (!string.IsNullOrWhiteSpace(tenant))
        {
            url = QueryHelpers.AddQueryString(url, "__tenant", tenant);
        }

        NavigationManager.NavigateTo(url);
    }

    private string? GetCurrentTenantFromUrl()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("__tenant", out var tenantValues))
        {
            var tenant = tenantValues.ToString();
            return string.IsNullOrWhiteSpace(tenant) ? null : tenant;
        }

        return null;
    }

    private bool CanEditAnyGoalField()
    {
        if (_goal is null)
        {
            return false;
        }

        return IsEditAccess(_goal.ProgressPercentAccess)
            || IsEditAccess(_goal.ActualValueAccess)
            || IsEditAccess(_goal.NoteAccess)
            || IsEditAccess(_goal.AttachmentAccess);
    }

    private static bool IsEditAccess(string? access)
        => string.Equals(access, "Edit", StringComparison.OrdinalIgnoreCase);

    private static string YesNo(bool value) => value ? "Sě" : "No";

    private static string FormatDate(DateOnly? value)
        => value?.ToString("dd/MM/yyyy") ?? "-";

    private static string FormatDecimal(decimal? value)
        => value?.ToString("0.##") ?? "-";

    public class AddProgressFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public DateOnly EntryDate { get; set; }

        [Range(0, 100)]
        public decimal? ProgressPercent { get; set; }

        public decimal? ActualValue { get; set; }

        [StringLength(2000)]
        public string? Note { get; set; }
    }
}