{
  "App": {
    "SelfUrl": "https://<staging-url>",
    "RedirectAllowedUrls": "https://<staging-url>",
    "DisablePII": true,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/staging-log-.txt",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 14
              }
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=<sql-server>;Database=<database>;User Id=<user>;Password=<password>;Encrypt=True;TrustServerCertificate=True"
  },
  "AuthServer": {
    "Authority": "https://<staging-url>",
    "RequireHttpsMetadata": true,
    "CertificatePassPhrase": "<certificate-passphrase>"
  },
  "Sso": {
    "OpenIdConnect": {
      "Enabled": false,
      "Scheme": "CorporateOidc",
      "DisplayName": "Corporate SSO",
      "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
      "ClientId": "<client-id>",
      "ClientSecret": "<client-secret>",
      "ResponseType": "code",
      "CallbackPath": "/signin-corporate-oidc",
      "SignedOutCallbackPath": "/signout-corporate-oidc",
      "RequireHttpsMetadata": true,
      "SaveTokens": true,
      "GetClaimsFromUserInfoEndpoint": true,
      "Scopes": [
        "openid",
        "profile",
        "email"
      ],
      "Claims": {
        "Name": "name",
        "UserName": "preferred_username",
        "Email": "email",
        "Role": "roles"
      }
    },
    "RoleMappings": {
      "admin": [
        "SuccessFactor.Admin",
        "SF_Admin"
      ],
      "HR": [
        "SuccessFactor.HR",
        "SF_HR"
      ],
      "Responsabile": [
        "SuccessFactor.Manager",
        "SF_Manager"
      ],
      "Dipendente": [
        "SuccessFactor.Employee",
        "SF_Employee"
      ]
    }
  },
  "SuccessFactor": {
    "Notifications": {
      "Email": {
        "Enabled": false,
        "Provider": "Smtp",
        "FromAddress": "successfactor-staging@example.invalid",
        "FromName": "SuccessFactor Staging",
        "Smtp": {
          "Host": "<smtp-host>",
          "Port": 25,
          "UserName": "",
          "Password": "",
          "EnableSsl": false
        }
      }
    }
  },
  "Blazorise": {
    "ProductToken": ""
  },
  "StringEncryption": {
    "DefaultPassPhrase": "<string-encryption-passphrase>"
  },
  "RemoteServices": {
    "Default": {
      "BaseUrl": "https://<staging-url>/"
    }
  }
}
